{
  "name": "ghost-empire",
  "version": "0.1.0",
  "private": true,
  "description": "Ghost Empire / E-Forge monorepo — root pakiet trzyma WYŁĄCZNIE orkiestrację repo-wide: wydania (semantic-release) oraz git-hooki + walidację commitów (lefthook + commitlint). Aplikacja żyje w ghost-empire-web/, bot w ghost-empire-chat/ (własne package.json).",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "lefthook install",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run --no-ci"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.6",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/gitlab": "^13.2.6",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "lefthook": "^1.10.10",
    "semantic-release": "^24.2.9"
  }
}
