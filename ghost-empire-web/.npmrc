# next-auth@5 beta declares an OPTIONAL peer of @simplewebauthn@^9, but we intentionally
# run @simplewebauthn@13 (#629 — code adapted to v13 + tested). Without this, Vercel's fresh
# `npm install` fails with ERESOLVE and the deploy errors (local `npm ci` replays the lockfile
# and never re-resolves, which is why the gates missed it — #654). legacy-peer-deps restores
# npm-v6 behaviour: ignore the optional-peer version conflict. The lockfile already pins v13.
legacy-peer-deps=true
