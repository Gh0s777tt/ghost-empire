# =====================================================
# GHOST EMPIRE — TEMPLATE ZMIENNYCH ŚRODOWISKOWYCH
# =====================================================
# Skopiuj ten plik jako .env.local i uzupełnij wartości.
# NIGDY nie wpisuj tutaj prawdziwych sekretów — ten plik trafia do gita!
# =====================================================

# --- NEXTAUTH ---
# Wygeneruj nowy: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_BASE64_32_BYTES
NEXTAUTH_URL=http://localhost:3000

# --- DATABASE (Supabase via Supavisor pooler) ---
# Supabase Dashboard -> Project Settings -> Database -> Connection string
# Wybierz "Transaction" dla DATABASE_URL i "Session" dla DIRECT_URL.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- TWITCH OAuth ---
# dev.twitch.tv/console -> Applications
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- DISCORD OAuth ---
# discord.com/developers/applications -> Twoja aplikacja -> OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- BOT SECRET (Discord bot <-> API) ---
# Wygeneruj: openssl rand -hex 32
# Ten sam string wklej do .env bota Discord.
BOT_SECRET=REPLACE_WITH_HEX_32_BYTES

# --- DISCORD BOT TOKEN ---
# discord.com/developers/applications -> Twoja aplikacja -> Bot -> Reset Token
DISCORD_BOT_TOKEN=

# --- DISCORD GUILD ID ---
# Discord -> Tryb dewelopera -> PPM na serwer -> Kopiuj ID
DISCORD_GUILD_ID=

# --- KICK (faza 2) ---
# KICK_CLIENT_ID=
# KICK_CLIENT_SECRET=

# --- CLOUDINARY (faza 3) ---
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- ADMIN ---
# Twój Discord user ID (Tryb dewelopera -> PPM na siebie -> Kopiuj ID)
ADMIN_DISCORD_ID=

# --- STREAM ALERTS (OBS overlay) ---
# Wygeneruj: openssl rand -hex 32
# OBS browser source URL: https://ghost-empire-web.vercel.app/overlay?token=<ten_token>
# NIE pokazuj nikomu — kto ma token może widzieć alerty live (ale nie może ich tworzyć).
OVERLAY_TOKEN=REPLACE_WITH_HEX_32_BYTES
