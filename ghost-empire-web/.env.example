# =====================================================
# GHOST EMPIRE (web) — TEMPLATE ZMIENNYCH ŚRODOWISKOWYCH
# =====================================================
# Skopiuj ten plik jako .env.local i uzupełnij wartości.
# NIGDY nie wpisuj tutaj prawdziwych sekretów — ten plik trafia do gita!
# Pełna referencja WSZYSTKICH zmiennych (w tym botów): docs/ENV.md
# =====================================================

# =====================================================
# RDZEŃ (wymagane do uruchomienia)
# =====================================================

# --- NEXTAUTH ---
# Wygeneruj nowy: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_BASE64_32_BYTES
NEXTAUTH_URL=http://localhost:3000

# --- DATABASE (Supabase) ---
# Supabase Dashboard → Project Settings → Database → Connection string.
# DATABASE_URL = "Transaction" pooler (port 6543); DIRECT_URL = "Session"/direct (5432, migracje/db push).
# connection_limit=3 — patrz docs/ENV.md (na 1 pula się zatyka).
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=3&pool_timeout=20
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- BOT SECRET (boty <-> API: /api/internal/*, /api/bot/*) ---
# Wygeneruj: openssl rand -hex 32 — TEN SAM string ustaw w botach (ghost-empire-chat, E-Bot).
BOT_SECRET=REPLACE_WITH_HEX_32_BYTES

# --- ENCRYPTION_KEY (szyfrowanie sekretów at-rest, AES-256-GCM) ---
# Opcjonalny: gdy brak, używany jest NEXTAUTH_SECRET. W PROD ustaw dedykowany,
# by odpiąć szyfrowanie od auth. ⚠️ Zmiana klucza = stare zaszyfrowane wartości
# (klucze API / tokeny OAuth) stają się nieczytelne. Wygeneruj: openssl rand -hex 32
# ENCRYPTION_KEY=

# =====================================================
# LOGOWANIE (OAuth) — wymagane dla danego dostawcy
# Redirect URI w konsoli: https://<domena>/api/auth/callback/<provider>
# =====================================================

# --- TWITCH --- (dev.twitch.tv/console)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- DISCORD --- (discord.com/developers → OAuth2)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- GOOGLE → YouTube --- (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- KICK --- (dev.kick.com)
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# =====================================================
# ADMIN / ROLE
# =====================================================
# Twój Discord user ID (Tryb dewelopera → PPM na siebie → Kopiuj ID) → admin przy logowaniu Discordem.
ADMIN_DISCORD_ID=
# Dodatkowe maile = stały admin (po przecinku). Mail właściciela jest hardcodowany w auth.ts.
# ADMIN_EMAILS=

# =====================================================
# OPCJONALNE INTEGRACJE (włącz wg potrzeb — szczegóły: docs/ENV.md)
# Klucze AI / Sentry / OBS wklejasz też NA STRONIE w /admin#integrations (baza nadpisuje env).
# =====================================================

# --- Stream / donacje ---
# TWITCH_EVENTSUB_SECRET=          # podpis webhooków Twitch (suby/gifty/bity)
# STREAMLABS_CLIENT_ID=
# STREAMLABS_CLIENT_SECRET=
# DONATION_GT_PER_PLN=100
# PAYMEDIA_WEBHOOK_SECRET=
# PAYMEDIA_GT_PER_PLN=
# OVERLAY_TOKEN=                   # legacy/fallback — token auto-generowany w /admin#alerts

# --- AI / gry / media (fallback env; preferowane /admin#integrations) ---
# AI_API_KEY=
# AI_PROVIDER=openai               # openai | anthropic | grok | gemini | deepseek | bielik
# AI_MODEL=gpt-4o-mini
# STEAM_API_KEY=                   # biblioteka gier /games (steamcommunity.com/dev/apikey)
# RUMBLE_API_URL=                  # overlay /overlay/rumble
# PSN_NPSSO=                       # biblioteka gier PSN (wygasa ~60 dni)
# SENTRY_DSN=                      # error tracking (czytane przy starcie z env)

# --- Infrastruktura ---
# CRON_SECRET=                     # crony Vercel (streamlabs-poll / prune / weekly-rewards)
# UPSTASH_REDIS_REST_URL=          # współdzielony cache (bez → in-memory per instancja)
# UPSTASH_REDIS_REST_TOKEN=
# LOG_LEVEL=info                   # debug | info | warn | error
# NEXT_PUBLIC_SITE_URL=            # publiczny bazowy URL (fallback do NEXTAUTH_URL)

# --- Web Push (uśpione bez kluczy + db push tabeli push_subscriptions) ---
# Wygeneruj: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ty@domena

# --- SaaS multi-tenant + Stripe (dry-wired; bez nich = pojedynczy tenant, checkout 503) ---
# NEXT_PUBLIC_ROOT_DOMAIN=         # subdomeny per tenant (<slug>.domena)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO_1M=             # wzorzec: STRIPE_PRICE_{PRO|ELITE|BASIC}_{1|3|6|12}M

# =====================================================
# BOTY mają WŁASNE pliki .env (nie tutaj):
#   ghost-empire-chat (czat Twitch/Kick/YT) i E-Bot (Discord, GHOST_* vars) — patrz docs/ENV.md §2–§3
# =====================================================
