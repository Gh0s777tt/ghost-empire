// prisma/schema.prisma
// Ghost Empire - Full Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================================
// TENANCY (multi-tenant SaaS — Phase 1 scaffold)
// =====================================================
// One row per streamer/customer. Phase 1 introduces the model + User.tenantId
// (nullable, backfilled to the default tenant). Later phases scope the remaining
// models, resolve the tenant from the request subdomain, and make tenantId
// required once every row is attributed.

model Tenant {
  id                   String    @id @default(cuid())
  slug                 String    @unique // subdomain + URL key, e.g. "ghost-empire"
  name                 String // brand display name, e.g. "GH0ST EMPIRE"
  shortName            String? // manifest short_name / compact UI
  brandColor           String    @default("#E50914")
  logoUrl              String?
  domain               String?   @unique // optional custom apex domain → this portal (#653, e.g. "empire-forge.com"); null = subdomain/default only
  // White-label currency naming (Phase 5): i18n catalogs carry %tokenName%/%gt%
  // markers that the message loader replaces with these per-tenant values.
  tokenName            String    @default("Ghost Tokens") // full currency name, e.g. "Neo Coins"
  tokenSymbol          String    @default("GT") // short unit shown next to amounts
  companionDefaultName String? // per-portal default name for new Ghost Companions (#audit3); null → "Widmo"
  bgImageUrl           String? // optional portal background image (#audit3); rendered behind a dark overlay
  // Portal's own social links (#audit3): JSON array of { platform, url } shown in the
  // footer/about — per-portal so each streamer shows THEIR channels (not the founder's).
  socialLinks          Json? // [{ platform: "twitch"|"kick"|…, url }]; null → founder default (SOCIALS)
  // Support-engagement alerts (#audit3): notify the streamer when a viewer opens/copies a
  // payment method on /support. "none" | "bell" (in-app notification) | "overlay" (OBS) | "both".
  // A click is an intent signal, not a confirmed payment — throttled server-side.
  supportAlertMode     String    @default("none")
  // IANA timezone the portal's /schedule times are shown in (#audit5); null → "Europe/Warsaw".
  timezone             String?
  ownerHandle          String? // streamer's public handle (%owner% in i18n), e.g. "Gh0s77tt"
  // Phase 6 — billing/entitlements. The founder tenant defaults to "elite" so the
  // existing portal never gates itself; paying tenants get their plan at checkout.
  plan                 String    @default("elite") // "basic" | "pro" | "elite"
  planExpiresAt        DateTime? // null = never (founder); past date = expired → basic features
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  ownerUserId          String? // streamer-admin who owns this tenant (plain ref — no relation, to avoid a second User<->Tenant edge)
  ownerEmail           String? // owner's login email — first sign-in on the tenant's subdomain with this email gets isAdmin (Phase 6 onboarding)
  // Per-tenant bot secret (Batch B). Optional: when set, the bot can authenticate
  // to this portal's internal endpoints with its own secret instead of the shared
  // global BOT_SECRET. Verification ALWAYS still accepts the global secret, so the
  // running single bot keeps working — enforcement-per-tenant lights up only once
  // each tenant runs its own bot instance with this secret. See verifyBotSecretForTenant.
  botSecret            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Phase 3 will scope the remaining models; User is the anchor relation.
  users     User[]
  // Viewers who follow this portal (cross-portal "switch streamers" hub, #508).
  followers PortalFollow[]

  @@map("tenants")
}

// =====================================================
// STREAMER HUB (#508) — cross-portal follow + switch
// =====================================================
// A viewer "follows" a streamer's portal so it shows in their hub and they can
// jump between favorite portals from anywhere. Additive + non-breaking: built on
// the existing shared identity (one User per person), so it touches NO auth/account
// code. A row simply records "this user follows this tenant's portal".
model PortalFollow {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("portal_follows")
}

// =====================================================
// USER & AUTH
// =====================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  // Per-tenant identity (Stage C, #511): email is unique PER PORTAL, not globally —
  // the same person reuses one email across portals. See @@unique([email, tenantId]).
  email         String?
  emailVerified DateTime?
  image         String?

  // Identity
  username    String? @unique
  displayName String?
  bio         String?
  country     String? // ISO-3166-1 alpha-2 (e.g. "PL") → flag on profile (#540)
  profileAccent String? // accent preset key (e.g. "violet") → profile glow/ring (#546)

  // Economy
  tokens      Int @default(0)
  totalEarned Int @default(0)
  totalSpent  Int @default(0)

  // Referrals — own shareable code + who invited this user (set once on claim)
  referralCode String? @unique
  referredById String?
  // Donation verification code (#audit3): the viewer puts this in their donation message
  // so a Streamlabs donation is credited to them (verified) — see lib/donation-code.
  donationCode String? @unique

  // Progression
  level          Int       @default(1)
  xp             Int       @default(0)
  prestige       Int       @default(0) // Phantom Ascension: +1 per PRESTIGE_XP of lifetime XP past the level cap (never resets)
  streak         Int       @default(0)
  lastStreakDate String? // "YYYY-MM-DD"
  lastDaily      DateTime?

  // Stats
  messageCount Int @default(0)
  voiceMinutes Int @default(0)

  // Security — opt-in TOTP step-up for sensitive admin actions.
  // totpSecret is encrypted at rest (lib/crypto); totpEnabledAt set once confirmed.
  totpSecret    String?
  totpEnabledAt DateTime?

  // Discord link
  discordId       String? @unique
  discordUsername String?

  // Admin & roles
  isAdmin        Boolean  @default(false)
  isModerator    Boolean  @default(false)
  isDonator      Boolean  @default(false)
  totalDonated   Int      @default(0) // suma donejtów (w jednostkach umownych, np. groszach)
  modNote        String? // notatka admina
  modPermissions String[] @default([]) // ["create_events","grant_tokens","ban_users","manage_shop","draw_events","mark_subs"]

  // Site-level ban/mute (independent of platform bans)
  isBanned    Boolean   @default(false)
  bannedUntil DateTime? // null = permanent
  banReason   String?

  // Tenancy (multi-tenant SaaS). Phase 1: nullable + backfilled to the default
  // tenant; a later phase makes it required once every row is scoped.
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // App relations
  connections      Connection[]
  transactions     Transaction[]
  userAchievements UserAchievement[]
  userTasks        UserTask[]
  socialLinks      SocialLink[]
  eventEntries     EventEntry[]
  raffleTickets    RaffleTicket[]
  notifications    Notification[]
  donations        Donation[]
  pollVotes        PollVote[]
  clipVotes        ClipVote[]
  portalFollows    PortalFollow[]
  triviaAnswers    TriviaAnswer[]
  pushSubscriptions PushSubscription[]
  passkeys         Passkey[]
  collectibles     UserCollectible[]
  cardListings     CardListing[]     @relation("CardSeller")
  wheelSpins       WheelSpin[]
  gtGamePlays      GtGamePlay[]
  duelsChallenged  Duel[]            @relation("DuelChallenger")
  duelsOpposed     Duel[]            @relation("DuelOpponent")
  duelsWon         Duel[]            @relation("DuelWinner")
  heistEntries     HeistEntry[]
  companion        Companion?
  shippingProfile  ShippingProfile?
  supportTickets   SupportTicket[]
  bountiesCreated  Bounty[]
  bountyPledges    BountyPledge[]
  leagueResults    LeagueSeasonResult[]
  clanId           String?
  clanRole         String? // "owner" | "member" within `clan`
  clan             Clan?             @relation("ClanMembers", fields: [clanId], references: [id])

  // Ranking + homepage top-users sort on these (DESC, filtered > 0). The single-column
  // indexes serve the global/legacy sort; the per-tenant leaderboards (#audit4) filter by
  // tenantId THEN sort, which a lone [tokens] index can't fully serve — so add composites
  // [tenantId, <sortKey>] so a portal's board is a pure index range scan as tenants grow.
  @@index([tokens])
  @@index([totalEarned])
  @@index([level, xp])
  @@index([streak])
  @@index([tenantId])
  @@index([tenantId, tokens])
  @@index([tenantId, totalEarned])
  @@index([tenantId, level, xp])
  @@index([tenantId, streak])
  @@index([clanId])
  @@index([referredById])
  // Per-tenant identity (Stage C, #511): email unique within a portal, not globally.
  // (username stays globally @unique — its sign-in collision handler covers dups.)
  @@unique([email, tenantId])
  @@map("users")
}

// Clip of the Week — community votes on the streamer's recent Twitch clips.
// One vote per user per ISO week (you pick your single favourite); changing it
// updates the row. Clips themselves come live from Helix (not stored).
model ClipVote {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String
  clipId    String // Twitch clip id
  week      String // ISO week key, e.g. "2026-W25"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, week]) // one vote per user per week
  @@index([tenantId, week])
  @@index([clipId])
  @@map("clip_votes")
}

// A per-user "Ghost Companion" — an idle pet that grows with fed GT and evolves
// through stages. Feeding BURNS GT out of circulation (a real economy sink, the
// counterpart to all the GT faucets). xp = lifetime GT fed; stage derived in
// lib/companion.ts. One per user (@unique), cascades on account delete.
model Companion {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String    @default("Widmo")
  xp        Int       @default(0)
  lastFedAt DateTime?
  tenantId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, xp]) // per-tenant companion leaderboard (ORDER BY xp DESC) #perf
  @@map("companions")
}

// Shipping/contact PII for fulfilling PHYSICAL rewards (#audit3). Kept in its own table
// (out of the heavily-`select`ed users table) so it can never be swept into a select-less
// query and can be dropped independently for GDPR erasure. Every sensitive field is stored
// ENCRYPTED at rest (AES-256-GCM via lib/crypto enc:v1:); `country` is plaintext (ISO-2,
// low-sensitivity, shown for display). Collected only with explicit consent (consentAt);
// the owner reads/edits/deletes their own row — never exposed publicly.
model ShippingProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  tenantId     String? // scope + per-tenant erasure
  fullName     String?   @db.Text // encrypted
  phone        String?   @db.Text // encrypted
  email        String?   @db.Text // encrypted (separate from login email)
  addressLine  String?   @db.Text // encrypted
  city         String?   @db.Text // encrypted
  postalCode   String?   @db.Text // encrypted
  parcelLocker String?   @db.Text // encrypted — InPost/other locker code or address
  country      String? // ISO-2, plaintext (display only)
  consentAt    DateTime? // when the user consented to storing shipping PII
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("shipping_profiles")
}

// A clan/team: viewers band together and pool GT into a shared treasury (a real
// economy SINK), then climb the clan leaderboard. One clan per user (User.clanId);
// `ownerUserId` is the founder (plain id used for permission checks, not a relation).
model Clan {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  tag         String
  ownerUserId String
  treasury    Int      @default(0)
  warPoints   Int      @default(0) // GT contributed during the ACTIVE clan war; reset when a new war starts
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     User[]   @relation("ClanMembers")

  @@unique([tenantId, tag])
  @@index([tenantId])
  @@index([treasury])
  @@index([warPoints])
  @@index([tenantId, treasury]) // per-tenant clan ranking by treasury #perf
  @@index([tenantId, warPoints]) // per-tenant clan-war ranking #perf
  @@map("clans")
}

// A time-boxed clan war: clans earn `warPoints` (= GT members contribute during the
// window); the admin starts/ends it and the top clan wins the prize pool into its
// treasury. One active war per tenant at a time.
model ClanWar {
  id           String   @id @default(cuid())
  tenantId     String?
  name         String
  startsAt     DateTime @default(now())
  endsAt       DateTime
  status       String   @default("active") // "active" | "ended"
  prizePool    Int      @default(0) // GT awarded to the winner's treasury on resolve
  winnerClanId String?
  winnerTag    String?
  winnerPoints Int?
  createdAt    DateTime @default(now())

  @@index([tenantId, status])
  @@map("clan_wars")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  // Per-tenant identity (Stage A, #510): which portal this provider link belongs to.
  // Nullable + additive — backfilled from user.tenantId, then Stage C flips the unique
  // below to [provider, providerAccountId, tenantId] so one identity links once PER
  // tenant. NULL = legacy/pre-backfill (the tenant-aware adapter self-heals it).
  tenantId          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Stage C (#511): per-tenant — one provider identity links once PER portal. The
  // tenant-aware adapter (lib/auth-adapter.ts) scopes lookups by tenantId.
  @@unique([provider, providerAccountId, tenantId])
  @@index([tenantId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// =====================================================
// PASSKEYS / WebAuthn (#543) — passwordless credentials, ADDITIVE and isolated.
// Registration (this stage) does NOT touch the OAuth login flow; login via passkey
// (#544) creates a Session row directly (DB session strategy), never altering the
// NextAuth config. credentialId/publicKey are base64url strings.
// =====================================================
model Passkey {
  id           String    @id @default(cuid())
  userId       String
  credentialId String    @unique // base64url credential id
  publicKey    String    @db.Text // base64url COSE public key
  counter      Int       @default(0) // signature counter (clone-detection)
  transports   String? // CSV: "usb,nfc,ble,internal,hybrid"
  deviceName   String? // user-facing label, e.g. "iPhone", "YubiKey"
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkeys")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =====================================================
// PLATFORM CONNECTIONS
// =====================================================

model Connection {
  id          String  @id @default(cuid())
  userId      String
  platform    String // "twitch" | "kick" | "youtube" | "discord"
  platformId  String // user's ID on that platform
  username    String
  displayName String?
  avatar      String?

  // OAuth tokens (encrypted in production)
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  tokenExpiry  DateTime?

  // Sub status
  isSubscriber Boolean   @default(false)
  subTier      String? // "T1" | "T2" | "T3" | "Prime"
  subMonths    Int       @default(0)
  subStartDate DateTime?

  // Platform role (Twitch mod, Discord admin, Kick mod, etc.)
  isModerator Boolean @default(false) // mod na DANEJ platformie
  isVip       Boolean @default(false) // VIP na Twitch / equivalent
  isOG        Boolean @default(false) // Kick OG (original supporter)

  // Platform-side ban/mute (set by streamer/mods on tej platformie)
  isBanned  Boolean @default(false)
  isMuted   Boolean @default(false)
  banReason String?

  // Platform metrics
  bits       Int? // Twitch lifetime bits cheered
  kickPoints Int? // Kick channel points
  subCount   Int? // sub count of THIS user's channel (if streamer themselves)

  // Cached stats (updated via webhook/cron)
  followers Int?
  following Int?
  viewCount Int?

  connectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@unique([platform, platformId])
  // Webhook handlers (Twitch/Kick) look up the linked account by platform + username
  // on every sub/cheer/gift event — index the equality columns.
  @@index([platform, username])
  @@map("connections")
}

// =====================================================
// ECONOMY
// =====================================================

model Transaction {
  id     String @id @default(cuid())
  userId String

  type   String // "earn" | "spend" | "admin_grant" | "admin_deduct" | "refund"
  amount Int // positive = earn, negative = spend

  reason     String
  multiplier Float  @default(1.0)

  // External payment id (e.g. "paymedia:<payment_id>") — unique, so a concurrent
  // webhook retry loses with P2002 instead of double-crediting. NULL for
  // non-payment transactions (Postgres allows many NULLs in a unique column).
  externalId String? @unique

  // If purchase
  shopItemId String?
  shopItem   ShopItem? @relation(fields: [shopItemId], references: [id])

  // Delivery status (for physical/digital items)
  status String  @default("completed") // "pending" | "completed" | "delivered" | "refunded"
  note   String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Highest-write table (insert per chat message) — had ZERO indexes.
  // [userId, createdAt]: profile history + daily-bonus lookback.
  // [type, createdAt]: weekly-ranking groupBy + pending-orders + anomaly scan.
  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("transactions")
}

// =====================================================
// SHOP
// =====================================================

model ShopItem {
  id          String  @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection (many rows/tenant, NOT unique)
  name        String
  description String  @db.Text
  category    String // "games" | "skins" | "subs" | "cosmetic" | "experience"
  price       Int

  imageUrl   String?
  imageEmoji String? @default("🎁")

  stock      Int @default(-1) // -1 = unlimited
  totalStock Int @default(-1)

  hot      Boolean @default(false)
  active   Boolean @default(true)
  featured Boolean @default(false)

  // Requirements
  requiresSubTier     String? // "T1" | "T2" | "T3" | "DUAL"
  requiresMinLevel    Int?
  requiresMinMonths   Int?
  requiresAchievement String? // Achievement.code that must be earned to unlock this item

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]

  @@index([tenantId])
  @@map("shop_items")
}

// =====================================================
// EVENTS
// =====================================================

model Event {
  id          String  @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection (many rows/tenant, NOT unique)
  type        String // "giveaway" | "raffle" | "contest" | "happy_hour"
  name        String
  description String? @db.Text

  active   Boolean   @default(true)
  startsAt DateTime?
  endsAt   DateTime?

  // Happy Hour fields
  multiplier Float?

  // Giveaway / Contest / Raffle fields
  prize         String?
  prizeImageUrl String?
  winnersCount  Int?
  requirement   String?

  // Raffle specific
  ticketPrice       Int?
  maxTicketsPerUser Int?
  // Keyword raffle (#audit3): viewers enter for FREE by typing raffleKeyword in chat
  // (bot → /api/internal/raffle-entry). Subs/mods get extra tickets (weight) = higher odds.
  raffleKeyword     String?
  raffleSubWeight   Int     @default(2)
  raffleModWeight   Int     @default(2)

  // Auto-draw
  autoDrawAt DateTime?
  drawnAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  entries       EventEntry[]
  raffleTickets RaffleTicket[]

  @@index([tenantId])
  @@map("events")
}

model EventEntry {
  id      String @id @default(cuid())
  eventId String
  userId  String

  isWinner  Boolean   @default(false)
  claimedAt DateTime?

  joinedAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_entries")
}

model RaffleTicket {
  id           String @id @default(cuid())
  eventId      String
  userId       String
  ticketNumber Int

  boughtAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("raffle_tickets")
}

// =====================================================
// ACHIEVEMENTS
// =====================================================

model Achievement {
  id          String  @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection
  code        String // unique PER TENANT (see @@unique below) — was globally @unique
  name        String
  description String
  icon        String
  rarity      String // "common" | "rare" | "epic" | "legendary"
  hidden      Boolean @default(false)

  // Trigger conditions (checked by engine)
  triggerType  String? // "level" | "tokens_earned" | "streak" | "messages" | "manual"
  triggerValue Int?

  xpReward    Int     @default(0)
  tokenReward Int     @default(0)
  rewardNote  String? // optional non-token reward shown when earned (game key / item / role / etc.)

  createdAt DateTime @default(now())

  userAchievements UserAchievement[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// =====================================================
// DAILY TASKS
// =====================================================

model DailyTask {
  id       String  @id @default(cuid())
  tenantId String? // multi-tenant (#512) — each portal has its own quests
  code     String // unique PER TENANT (see @@unique below) — was globally @unique
  text     String
  textEn   String?

  target      Int
  reward      Int
  bonusReward Int @default(0)

  triggerType String // "messages" | "voice_minutes" | "drop_code" | "shop_purchase" | "manual"
  active      Boolean @default(true)

  userTasks UserTask[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("daily_tasks")
}

model UserTask {
  id     String @id @default(cuid())
  userId String
  taskId String
  date   String // "YYYY-MM-DD" — resets daily

  progress  Int       @default(0)
  done      Boolean   @default(false)
  claimed   Boolean   @default(false)
  claimedAt DateTime?

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task DailyTask @relation(fields: [taskId], references: [id])

  @@unique([userId, taskId, date])
  @@map("user_tasks")
}

// =====================================================
// SOCIAL LINKS
// =====================================================

model SocialLink {
  id       String @id @default(cuid())
  userId   String
  platform String // "instagram" | "twitter" | "tiktok" | "youtube" | "website"
  handle   String
  url      String
  clicks   Int    @default(0) // # of times opened from a public profile (#542, directional)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("social_links")
}

// =====================================================
// NOTIFICATIONS
// =====================================================

model Notification {
  id     String @id @default(cuid())
  userId String

  type    String // "achievement" | "task_reward" | "shop_delivered" | "event_win" | "system"
  title   String
  message String
  icon    String?
  link    String?
  read    Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // NotificationBell polls {userId} list + {userId, read:false} count every
  // 30-120s per logged-in user — was a seq scan. Covers both + prune by date.
  @@index([userId, createdAt])
  @@index([userId, read])
  @@map("notifications")
}

// Viewer → streamer support tickets (#audit5 new feature): an in-platform contact channel
// (e.g. "my physical reward didn't arrive", bug reports, questions). The viewer opens a ticket
// from /profile; the portal owner is notified and replies/resolves it in /admin#tickets.
model SupportTicket {
  id         String    @id @default(cuid())
  tenantId   String? // multi-tenant — per portal
  userId     String
  subject    String
  message    String    @db.Text
  category   String    @default("other") // "reward" | "bug" | "question" | "other" (#651 triage)
  status     String    @default("open") // "open" | "resolved"
  adminReply String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt]) // admin queue per portal, open first
  @@index([userId, createdAt]) // a viewer's own tickets
  @@map("support_tickets")
}

// =====================================================
// STREAM DROPS
// =====================================================

model StreamDrop {
  id          String  @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection
  code        String // unique PER TENANT (see @@unique below) — was globally @unique
  reward      Int
  bonusReward Int     @default(0)
  bonusSlots  Int     @default(10) // first N users get bonus
  claimCount  Int     @default(0) // atomic ordinal — incremented in-tx per claim so exactly the first `bonusSlots` get the bonus (#audit-M4)

  active      Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  createdById String?

  claims DropClaim[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("stream_drops")
}

// =====================================================
// AUDIT LOG (admin actions — for forensics + security)
// =====================================================

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String // user.id who did the action
  adminName  String? // snapshot of admin username at time of action
  action     String // "grant_tokens" | "create_drop" | "create_event" | "draw_event" | "deliver_order" | "refund_order" | "set_user_role" | "set_connection_role" | "deactivate_drop" | "deactivate_event"
  targetType String? // "user" | "drop" | "event" | "transaction" | "connection"
  targetId   String? // affected entity id
  details    String?  @db.Text // JSON-stringified payload for inspection
  ipAddress  String? // request IP (rough client identification)
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action, createdAt])
  // Admin dashboard reads the global recent log (ORDER BY createdAt DESC) —
  // the composite indexes above don't serve an unfiltered sort.
  @@index([createdAt])
  @@map("admin_actions")
}

// =====================================================
// RATE LIMIT BUCKETS (in-memory fallback; persisted for cross-instance state)
// =====================================================

// =====================================================
// BOT CONFIG — singleton (always id="default")
// Bot fetches from /api/bot/config periodically instead of reading env vars
// =====================================================

model BotConfig {
  id                     String   @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId               String?  @unique // multi-tenant (Phase 3)
  messageReward          Int      @default(5)
  messageCooldownSeconds Int      @default(60)
  voiceRewardPerMinute   Int      @default(10)
  voiceTickSeconds       Int      @default(60)
  afkGivesReward         Boolean  @default(false)
  mutedGivesReward       Boolean  @default(true)
  enabled                Boolean  @default(true)
  // Happy hours: GT-earn multiplier applied PORTAL-SIDE (chat-award / award routes)
  // inside the [start, end) window in Europe/Warsaw — the bot needs no changes.
  happyHourEnabled       Boolean  @default(false)
  happyHourStart         Int      @default(19) // hour 0-23, Europe/Warsaw
  happyHourEnd           Int      @default(22) // exclusive; start>end = overnight window
  happyHourMultiplier    Float    @default(2)
  updatedAt              DateTime @updatedAt

  @@map("bot_config")
}

// =====================================================
// CHAT COMMANDS — managed from /admin#chat, fetched by ghost-empire-chat
// (Twitch/Kick/YouTube bot) periodically. Replaces the bot's hardcoded list.
// =====================================================

model ChatCommand {
  id               String   @id @default(cuid())
  tenantId         String? // multi-tenant (Phase 3 bot models)
  trigger          String // first word that triggers it, e.g. "!portal" (lowercased)
  response         String   @db.Text // text the bot replies with
  cooldownSeconds  Int      @default(15) // per-command cooldown across all chatters
  enabled          Boolean  @default(true) // disabled commands are not sent to the bot
  // Conditional gating (evaluated bot-side from portal live status — Twitch StreamSession)
  requiresLive     Boolean  @default(false) // only fires while the stream is live
  activeFromMinute Int      @default(0) // only after the stream has been live N minutes (0 = always; implies live)
  createdById      String? // admin user id who created it
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // trigger is unique PER TENANT (each portal has its own !commands namespace).
  @@unique([tenantId, trigger])
  @@index([tenantId])
  @@map("chat_commands")
}

// =====================================================
// CHAT TIMERS — cyclic auto-messages the bot posts to all active platforms.
// Managed from /admin#timers, fetched by ghost-empire-chat.
// =====================================================

model ChatTimer {
  id              String   @id @default(cuid())
  tenantId        String? // multi-tenant (Phase 3 bot models)
  message         String   @db.Text // text broadcast on the interval
  intervalSeconds Int      @default(900) // how often to post (min 60s, enforced by the API)
  enabled         Boolean  @default(true)
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@map("chat_timers")
}

// =====================================================
// FAQ / AUTO-RESPONSES — bot replies when a message CONTAINS a keyword
// (not just !commands). Managed from /admin#faq, fetched by ghost-empire-chat.
// =====================================================

model FaqResponse {
  id              String   @id @default(cuid())
  tenantId        String? // multi-tenant (Phase 3 bot models)
  keyword         String // phrase/word to look for in a message
  matchType       String   @default("contains") // "contains" (substring) | "word" (whole word)
  response        String   @db.Text
  cooldownSeconds Int      @default(30)
  enabled         Boolean  @default(true)
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@map("faq_responses")
}

// =====================================================
// WELCOME — singleton config; bot greets a viewer's first message per stream.
// Managed from /admin#welcome, fetched by ghost-empire-chat.
// =====================================================

model WelcomeConfig {
  id          String   @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId    String?  @unique // multi-tenant (Phase 3)
  enabled     Boolean  @default(false)
  template    String   @default("Witaj {user}! Miło Cię widzieć 👋") @db.Text // {user} = chatter name
  bonusTokens Int      @default(0) // GT przyznawane raz/widz/sesję przy pierwszej wiadomości (0 = off)
  updatedAt   DateTime @updatedAt

  @@map("welcome_config")
}

// =====================================================
// SONG REQUESTS — viewers queue songs via "!sr <link>"; managed on /admin#songs.
// =====================================================

model SongRequest {
  id          String    @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3 bot models)
  query       String    @db.Text // link or title as typed by the viewer
  title       String? // resolved via oEmbed (YouTube/Spotify), if any
  requestedBy String // chatter display name
  platform    String // "twitch" | "kick" | "youtube"
  status      String    @default("queued") // "queued" | "playing" | "played" | "skipped"
  createdAt   DateTime  @default(now())
  playedAt    DateTime?

  @@index([status, createdAt])
  @@index([tenantId])
  @@map("song_requests")
}

// Per-tenant ban list for song requests: a chatter handle here can't enqueue via the bot
// (the streamer bans abusers from the admin Song Queue). Matched on the lowercased handle.
model SongRequestBan {
  id        String   @id @default(cuid())
  tenantId  String? // per-portal; null = legacy/founder
  name      String // lowercased chat handle banned from requesting
  createdAt DateTime @default(now())

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("song_request_bans")
}

// =====================================================
// CHAT FEED — recent chat messages from all platforms, pushed by the bot and
// shown on the /overlay/chat OBS browser source. Rolling buffer (old rows pruned).
// =====================================================

model ChatFeedMessage {
  id        String   @id @default(cuid())
  tenantId  String? // multi-tenant (Phase 4 overlay pass); null = legacy
  platform  String // "twitch" | "kick" | "youtube"
  username  String
  message   String   @db.Text
  emotes    String?  @db.Text // JSON: Twitch emote map { emoteId: ["start-end", …] } (code-point indices)
  badges    String? // JSON: Twitch badge map { broadcaster:"1", moderator:"1", subscriber:"12", vip:"1", … }
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@map("chat_feed_messages")
}

// =====================================================
// SUBATHON — singleton countdown extended by subs/gifts/donations (lib/subathon.ts).
// Overlay: /overlay/subathon?token=<OVERLAY_TOKEN>. Managed on /admin#subathon.
// =====================================================

model Subathon {
  id             String    @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId       String?   @unique // multi-tenant (Phase 3)
  active         Boolean   @default(false)
  startedAt      DateTime?
  endsAt         DateTime? // current countdown target
  secondsPerSub  Int       @default(300) // +time per sub (incl. gifted)
  secondsPerPln  Int       @default(60) // +time per 1 PLN donated
  maxEndsAt      DateTime? // optional hard cap (null = uncapped)
  totalAddedSecs Int       @default(0) // stat: total seconds added by events
  accentColor    String    @default("#E50914") // overlay card accent (hex)
  label          String    @default("Subathon") // overlay card heading text
  updatedAt      DateTime  @updatedAt

  @@map("subathon")
}

// =====================================================
// CHAT MODERATION — global automod config (singleton). Pure detectors live in
// lib/moderation.ts; the bot fetches this via /api/bot/moderation and enforces
// the action (delete / timeout / warn) on Twitch / Kick / YouTube.
// =====================================================

model ModerationConfig {
  id       String  @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId String? @unique // multi-tenant (Phase 3)
  enabled  Boolean @default(false) // master switch

  profanityEnabled     Boolean  @default(false)
  profanityWords       String[] @default([])
  profanityRegex       String[] @default([]) // power-user regex patterns (profanity action)
  profanityAction      String   @default("delete") // delete | timeout | warn
  profanityTimeoutSecs Int      @default(60)

  // Link / URL filter — blocks links unless their domain is whitelisted.
  linkEnabled     Boolean  @default(false)
  linkWhitelist   String[] @default([]) // allowed domain substrings (e.g. "twitch.tv")
  linkAllowSubs   Boolean  @default(true) // subs/VIP/mods may post links even if rule on
  linkAction      String   @default("delete")
  linkTimeoutSecs Int      @default(60)

  capsEnabled     Boolean @default(false)
  capsMinLetters  Int     @default(8)
  capsMaxRatioPct Int     @default(70) // percent 0-100
  capsAction      String  @default("delete")
  capsTimeoutSecs Int     @default(30)

  lengthEnabled     Boolean @default(false)
  lengthMax         Int     @default(300)
  lengthAction      String  @default("delete")
  lengthTimeoutSecs Int     @default(30)

  repeatEnabled     Boolean @default(false)
  repeatCharRun     Int     @default(8)
  repeatWordRun     Int     @default(4)
  repeatAction      String  @default("delete")
  repeatTimeoutSecs Int     @default(30)

  zalgoEnabled     Boolean @default(false)
  zalgoMaxRatioPct Int     @default(20)
  zalgoAction      String  @default("delete")
  zalgoTimeoutSecs Int     @default(30)

  exemptSubs Boolean @default(true)
  exemptVips Boolean @default(true)
  exemptMods Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("moderation_config")
}

// Per-violation log written by the bot after it enforces an automod action. Powers
// the moderation stats + top-offenders view, and records the escalation level.
model ModViolationLog {
  id         String   @id @default(cuid())
  tenantId   String? // Batch B: nullable for back-compat (null = legacy/founder rows). Admin stats scope by tenant.
  platform   String // "twitch" | "kick" | "youtube"
  username   String // lowercased login/handle of the offender
  violation  String // "profanity" | "caps" | "length" | "repeat" | "zalgo"
  action     String // enforced action AFTER escalation: "delete" | "timeout" | "warn"
  priorCount Int      @default(0) // offenses already in the window before this one
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([platform, username])
  @@index([tenantId, createdAt])
  @@map("mod_violation_logs")
}

// Outgoing webhooks — POST a JSON payload to an external URL (Discord, n8n, Zapier,
// custom) whenever a subscribed stream event fires. Optional HMAC secret signs the
// body (encrypted at rest). failCount auto-disables a dead endpoint.
model OutgoingWebhook {
  id          String    @id @default(cuid())
  tenantId    String? // multi-tenant (#512) — each portal has its own webhooks
  label       String
  url         String    @db.Text
  events      String[]  @default([]) // AlertType values, or ["*"] for every event
  secret      String? // optional HMAC signing secret (encrypted at rest)
  enabled     Boolean   @default(true)
  failCount   Int       @default(0) // consecutive failures; auto-disables at threshold
  lastStatus  Int? // last HTTP status (0 = network error)
  lastFiredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@map("outgoing_webhooks")
}

// =====================================================
// CHAT ACTIVITY HEATMAP — 7×24 buckets (day-of-week × hour, Europe/Warsaw),
// incremented by /api/internal/chat-award. Powers /admin#analytics.
// =====================================================

model ChatActivityBucket {
  tenantId  String // per-portal — each portal gets its own 7×24 heatmap (PK columns are NOT NULL; the chatter's user.tenantId is always set)
  dayOfWeek Int // 0=Sun .. 6=Sat (Europe/Warsaw)
  hour      Int // 0-23
  count     Int    @default(0)

  @@id([tenantId, dayOfWeek, hour])
  @@map("chat_activity_buckets")
}

// One broadcast session — opened by Twitch EventSub `stream.online`, closed by
// `stream.offline` (duration computed then). Powers "czas na streamie" + per-stream
// analytics. NB: EventSub only knows when the broadcaster is live, not per-viewer.
model StreamSession {
  id              String    @id @default(cuid())
  tenantId        String? // Batch B: nullable for back-compat (null = legacy/founder rows).
  platform        String    @default("twitch")
  twitchStreamId  String?   @unique // event.id from stream.online (idempotency)
  startedAt       DateTime
  endedAt         DateTime? // null = currently live
  durationSeconds Int? // set when the stream goes offline
  createdAt       DateTime  @default(now())

  @@index([startedAt])
  @@index([tenantId, startedAt])
  @@map("stream_sessions")
}

// =====================================================
// WHEEL OF FORTUNE (Koło Fortuny) — viewers spend GT to spin a weighted wheel
// =====================================================

model WheelConfig {
  id          String   @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId    String?  @unique // multi-tenant (Phase 3)
  enabled     Boolean  @default(false)
  costPerSpin Int      @default(100) // GT charged per spin
  segments    Json? // [{ label, weight, rewardTokens, color }]
  updatedAt   DateTime @updatedAt

  @@map("wheel_config")
}

model WheelSpin {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  segmentLabel String // label of the segment landed on
  rewardTokens Int // GT won (0 = no reward)
  cost         Int // GT spent to spin
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@map("wheel_spins")
}

// =====================================================
// GT MINI-GAMES — slots / coinflip gambling with Ghost Tokens (GT sink + engagement)
// =====================================================

model GtGamePlay {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      String // "slots" | "coinflip"
  bet       Int
  payout    Int // GT returned (0 = lost)
  net       Int // payout - bet
  detail    String? // e.g. slot symbols "🍒🍒🍒"
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([net])
  @@index([userId, createdAt]) // per-user history (casino "your recent games")
  @@map("gt_game_plays")
}

// PvP duel: two viewers stake the same bet, a fair coinflip decides the winner who takes
// the pot (minus a small rake = GT sink). Created by !duel, resolved by !accept. Both
// stakes are charged atomically at accept time (a throw rolls the whole transfer back).
model Duel {
  id             String    @id @default(cuid())
  platform       String // chat platform the duel lives on (twitch/kick/youtube)
  tenantId       String? // per-portal — the open-duel pool is scoped to one portal so two same-platform tenants never match into each other's duels (null = founder/legacy)
  challengerId   String
  challengerName String // chat handle, stored so the result can @-mention correctly
  opponentId     String? // null = open challenge (first !accept takes it)
  opponentName   String? // chat handle of the targeted opponent (null for open)
  bet            Int
  status         String    @default("pending") // pending | resolved | cancelled | expired
  winnerId       String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime // unaccepted duels expire (default 2 min)
  resolvedAt     DateTime?

  challenger User  @relation("DuelChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  opponent   User? @relation("DuelOpponent", fields: [opponentId], references: [id], onDelete: Cascade)
  winner     User? @relation("DuelWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@index([platform, tenantId, status]) // open-duel pool lookup is scoped per portal
  @@index([challengerId])
  @@index([createdAt])
  @@map("duels")
}

// Co-op heist: viewers join a crew with !heist <bet> over a short window; a collective
// success roll (chance scales with crew size) pays everyone WIN_MULT× on success, else the
// crew loses their stakes. Stakes are escrowed at join (atomic), so resolution only pays out
// the winners (atomic). Result math lives in lib/economy.ts; orchestration in lib/heist.ts.
model Heist {
  id          String       @id @default(cuid())
  platform    String // chat platform the heist lives on
  tenantId    String? // per-portal — the joinable-heist pool is scoped to one portal so two same-platform tenants never share a crew (null = founder/legacy)
  status      String       @default("open") // open | resolved | cancelled
  startedById String // user who opened the heist
  startedAt   DateTime     @default(now())
  resolvesAt  DateTime // join window closes / resolution time
  resolvedAt  DateTime?
  success     Boolean? // null until resolved
  entries     HeistEntry[]

  @@index([platform, tenantId, status]) // joinable-heist pool lookup is scoped per portal
  @@index([resolvesAt])
  @@index([startedAt])
  @@map("heists")
}

model HeistEntry {
  id      String @id @default(cuid())
  heistId String
  heist   Heist  @relation(fields: [heistId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name    String // chat handle (for the result message)
  bet     Int // escrowed at join

  @@unique([heistId, userId]) // one entry per user per heist
  @@index([userId])
  @@map("heist_entries")
}

// =====================================================
// GAME LIBRARY — aggregate owned games from platforms (Steam first; GOG/PSN later)
// =====================================================

model GameLibraryConfig {
  id            String    @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId      String?   @unique // multi-tenant (Phase 3)
  steamId       String? // SteamID64 (resolve vanity in admin)
  steamSyncedAt DateTime?
  // Per-portal PSN connect (#audit3): each streamer's own NPSSO, encrypted at rest
  // (lib/crypto). Falls back to the global PSN_NPSSO env when unset (back-compat).
  psnNpsso      String?
  psnSyncedAt   DateTime?
  // Per-portal Xbox connect (#audit3): the streamer's OpenXBL (xbl.io) API key, encrypted
  // at rest. Dormant until set; no global env fallback (Xbox had no integration before).
  xboxApiKey    String?
  xboxSyncedAt  DateTime?
  updatedAt     DateTime  @updatedAt

  @@map("game_library_config")
}

model Game {
  id           String    @id @default(cuid())
  tenantId     String? // multi-tenant (Phase 3) — per-portal game library (each streamer syncs their own)
  source       String // "steam" | "gog" | "psn" | "xbox"
  externalId   String // platform id (Steam appid, …)
  name         String
  imageUrl     String?
  playtimeMin  Int       @default(0) // total minutes played
  lastPlayedAt DateTime?
  hidden       Boolean   @default(false) // admin can hide a game from /games
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  votes        GameVote[]

  // Per-tenant uniqueness: two portals can each own the same Steam appid without colliding.
  // (Legacy null-tenant rows get claimed by the next sync / the backfill route.)
  @@unique([tenantId, source, externalId])
  @@index([source, playtimeMin])
  @@index([tenantId])
  @@map("games")
}

// "Vote for the next game" (#audit3) — each viewer picks ONE game per portal they'd like the
// streamer to play next. Free (no GT). Re-voting moves the single vote; cascades on game prune.
model GameVote {
  id        String   @id @default(cuid())
  tenantId  String? // multi-tenant — per portal
  gameId    String
  userId    String
  createdAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId]) // one active pick per viewer per portal
  @@index([tenantId, gameId]) // tally per portal
  @@index([gameId])
  @@map("game_votes")
}

// =====================================================
// STREAM SCHEDULE
// =====================================================

model StreamScheduleSlot {
  id              String   @id @default(cuid())
  tenantId        String? // multi-tenant (Phase 3) — collection: many rows per tenant (NOT unique)
  dayOfWeek       Int // 0=niedziela, 1=poniedziałek, ..., 6=sobota
  startHour       Int // 0-23
  startMinute     Int      @default(0)
  durationMinutes Int      @default(180) // domyślnie 3h
  title           String? // np. "Just chatting", "GTA RP"
  platform        String? // "twitch" | "kick" — gdzie streamuje tego dnia (opcjonalne)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([dayOfWeek, active])
  @@index([tenantId])
  @@map("stream_schedule")
}

// =====================================================
// TWITCH EVENTSUB — broadcaster token + subscriptions + event log
// =====================================================

model TwitchStreamerToken {
  id               String    @id @default(cuid()) // legacy singleton rows keep id "default"
  tenantId         String?   @unique // one streamer token per tenant (null = legacy)
  broadcasterId    String // Twitch user_id of the streamer (Gh0s77tt)
  broadcasterLogin String // Twitch username for display
  accessToken      String    @db.Text
  refreshToken     String?   @db.Text
  tokenExpiresAt   DateTime?
  scope            String // space-separated scopes granted
  connectedAt      DateTime  @default(now())
  connectedById    String? // admin user id who authorized

  @@index([broadcasterId]) // webhook events carry broadcaster_user_id → tenant lookup
  @@map("twitch_streamer_token")
}

model TwitchEventSubscription {
  id            String    @id // Twitch's subscription_id
  type          String // "channel.subscribe" | "channel.subscription.gift" | "channel.cheer"
  status        String // "enabled" | "webhook_callback_verification_pending" | ...
  broadcasterId String
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime? // last time we received an event of this type

  @@index([type])
  @@map("twitch_event_subscriptions")
}

model TwitchEvent {
  id            String   @id @default(cuid())
  eventId       String   @unique // Twitch message_id (for idempotency)
  type          String // event type
  payload       String   @db.Text // JSON of full event
  userId        String? // matched Ghost Empire user
  tokensGranted Int?
  receivedAt    DateTime @default(now())

  @@index([type, receivedAt])
  @@map("twitch_events")
}

// =====================================================
// STREAMLABS — singleton connection + donations
// =====================================================

model StreamlabsConnection {
  id                 String    @id @default(cuid()) // legacy singleton rows keep id "default"
  tenantId           String?   @unique // one connection per tenant (null = legacy)
  accessToken        String    @db.Text
  refreshToken       String?   @db.Text
  tokenExpiresAt     DateTime?
  scope              String?
  streamlabsUserId   String?
  streamlabsUsername String?
  lastPolledAt       DateTime?
  lastSeenDonationId String? // donation_id of most recent processed
  connectedAt        DateTime  @default(now())
  connectedById      String? // user.id who initiated OAuth

  @@map("streamlabs_connection")
}

model Donation {
  id           String   @id @default(cuid())
  tenantId     String? // Batch B: nullable for back-compat (null = legacy/founder rows). Streamlabs writes use conn.tenantId.
  externalId   String   @unique // donation_id from provider
  source       String   @default("streamlabs")
  donorName    String
  message      String?  @db.Text
  amountGrosze Int // amount * 100 (PLN cents)
  currency     String   @default("PLN")
  donatedAt    DateTime

  userId        String? // matched Ghost Empire user
  matchedAt     DateTime?
  matchType     String? // "auto_name" | "auto_mention" | "manual"
  tokensGranted Int? // GT credited to user

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([donatedAt])
  @@index([matchedAt])
  @@index([tenantId, donatedAt])
  @@map("donations")
}

model DiscordLinkCode {
  code      String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("discord_link_codes")
}

model RateLimitBucket {
  key         String   @id // e.g. "award:127.0.0.1" or "claim:userId"
  count       Int      @default(0)
  windowStart DateTime
  expiresAt   DateTime

  @@index([expiresAt])
  @@map("rate_limit_buckets")
}

model DropClaim {
  id        String   @id @default(cuid())
  dropId    String
  userId    String
  reward    Int // actual reward received (bonus or regular)
  claimedAt DateTime @default(now())

  drop StreamDrop @relation(fields: [dropId], references: [id])

  @@unique([dropId, userId])
  @@map("drop_claims")
}

// =====================================================
// STREAM ALERTS — OBS overlay queue
// Alerts dispatched by various endpoints; polled by /overlay browser source.
// =====================================================

model StreamAlert {
  id       String  @id @default(cuid())
  tenantId String? // multi-tenant (Phase 4 overlay pass); null = legacy
  type     String // "shop_purchase" | "event_win" | "drop_claim_bonus" | "twitch_sub" | "twitch_gift_sub" | "twitch_cheer" | "donation" | "welcome" | "level_up" | "test"

  title   String
  message String
  icon    String? // emoji shown in overlay

  // Actor (who triggered — for displaying avatar/username on the alert)
  actorName  String?
  actorImage String?

  // Numeric display (e.g. token amount, bits count, donation kwota)
  amount      Int?
  amountLabel String? // "GT" | "bits" | "PLN"

  meta String? @db.Text // optional JSON for type-specific extras

  createdAt DateTime  @default(now())
  shownAt   DateTime? // set when overlay first picks it up

  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, type, createdAt]) // recent/top supporters etc. (filter type, ORDER BY createdAt) #perf
  @@map("stream_alerts")
}

// =====================================================
// STREAM ALERT SETTINGS — singleton; per-type enable/disable + visuals
// =====================================================

// =====================================================
// BATTLE PASS / SEASONS — monthly-rolling tier progression
// =====================================================

model Season {
  id          String   @id @default(cuid())
  tenantId    String? // multi-tenant (#512) — each portal runs its own battle pass
  number      Int // sequential per tenant: 1, 2, 3, ... (was globally @unique)
  name        String // "Sezon 1: Pierwsza Krew" or "Maj 2026"
  description String?  @db.Text
  startsAt    DateTime
  endsAt      DateTime
  totalTiers  Int      @default(30)
  xpPerTier   Int      @default(5000)
  active      Boolean  @default(true) // false after rollover; only one active at a time
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rewards  SeasonReward[]
  progress UserSeasonProgress[]

  @@unique([tenantId, number])
  @@index([active, endsAt])
  @@index([tenantId])
  @@map("seasons")
}

model SeasonReward {
  id       String  @id @default(cuid())
  seasonId String
  tier     Int // 1..totalTiers
  premium  Boolean @default(false) // false = free track, true = premium pass only
  type     String // "tokens" | "badge" | "title" | "color" | "shop_unlock"
  label    String // display name
  value    String // payload: for tokens => "1000", for badge => achievement code, etc.
  icon     String?

  season Season                  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  claims UserSeasonRewardClaim[]

  @@unique([seasonId, tier, premium])
  @@index([seasonId, tier])
  @@map("season_rewards")
}

model UserSeasonProgress {
  id              String    @id @default(cuid())
  userId          String
  seasonId        String
  xp              Int       @default(0)
  tier            Int       @default(0) // computed from xp / season.xpPerTier
  premium         Boolean   @default(false) // true after buying premium pass
  premiumBoughtAt DateTime?
  updatedAt       DateTime  @updatedAt

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([seasonId, xp])
  @@map("user_season_progress")
}

model UserSeasonRewardClaim {
  id        String   @id @default(cuid())
  userId    String
  rewardId  String
  claimedAt DateTime @default(now())

  reward SeasonReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@unique([userId, rewardId])
  @@index([userId])
  @@map("user_season_reward_claims")
}

// =====================================================
// KICK INTEGRATION — webhooks for subs/gifts/chat (mirror of Twitch EventSub)
// =====================================================

model KickStreamerToken {
  id               String    @id @default(cuid()) // legacy singleton rows keep id "default"
  tenantId         String?   @unique // one streamer token per tenant (null = legacy)
  broadcasterId    String // Kick user_id (numeric, stored as string)
  broadcasterLogin String // Kick username/slug for display
  accessToken      String    @db.Text
  refreshToken     String?   @db.Text
  tokenExpiresAt   DateTime?
  scope            String // space-separated scopes granted
  connectedAt      DateTime  @default(now())
  connectedById    String? // admin user id who authorized

  @@index([broadcasterId]) // webhook events carry broadcaster id → tenant lookup
  @@map("kick_streamer_token")
}

model KickEventSubscription {
  id            String    @id // Kick's subscription id
  type          String // "chat.message.sent" | "channel.subscription.new" | "channel.subscription.gifts" | ...
  broadcasterId String
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime?

  @@index([type])
  @@map("kick_event_subscriptions")
}

model KickEvent {
  id            String   @id @default(cuid())
  eventId       String   @unique // Kick message_id for idempotency
  type          String
  payload       String   @db.Text // JSON of full event
  userId        String? // matched Ghost Empire user
  tokensGranted Int?
  receivedAt    DateTime @default(now())

  @@index([type, receivedAt])
  @@map("kick_events")
}

// =====================================================
// PREDICTIONS / BETS — viewers wager Ghost Tokens on outcomes
// =====================================================

model Prediction {
  id                  String    @id @default(cuid())
  tenantId            String? // multi-tenant (Phase 3) — collection (many rows/tenant, NOT unique)
  question            String    @db.Text
  options             String[] // labels for each option, order matches optionIndex
  status              String    @default("open") // "open" | "locked" | "resolved" | "cancelled"
  resolvedOptionIndex Int? // null until resolved
  totalPot            Int       @default(0) // sum of all wagers across all options
  opensAt             DateTime  @default(now())
  closesAt            DateTime? // wagers blocked after this (and status auto-flips to "locked")
  resolvedAt          DateTime?
  announceToChat      Boolean   @default(true) // bot re-announces this bet in chat while open
  accentColor         String    @default("#a855f7") // card accent (hex) on /predictions + overlay
  createdById         String? // admin user id
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  entries PredictionEntry[]

  @@index([status, opensAt])
  @@index([tenantId])
  @@map("predictions")
}

model PredictionEntry {
  id            String   @id @default(cuid())
  predictionId  String
  userId        String
  optionIndex   Int // which option they bet on
  tokensWagered Int // positive — deducted from User.tokens at wager time
  payout        Int      @default(0) // set on resolve; 0 if losing option
  wageredAt     DateTime @default(now())

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  @@unique([predictionId, userId]) // one wager per user per prediction
  @@index([userId])
  @@map("prediction_entries")
}

// =====================================================
// STREAM GOALS — visible progress bars on OBS overlay
// Auto-incremented when EventSub / Streamlabs handlers fire matching events.
// =====================================================

model StreamGoal {
  id          String    @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection (many rows/tenant, NOT unique)
  type        String // "subs" | "follows" | "donations_pln" | "cheers_bits" | "gift_subs" | "yt_members"
  label       String // admin custom text shown on overlay e.g. "500 subów = nowy setup!"
  current     Int       @default(0)
  target      Int
  active      Boolean   @default(true)
  resetMode   String    @default("manual") // "manual" | "per_stream" | "daily" | "weekly" | "monthly"
  lastResetAt DateTime?
  color       String? // overlay accent override; falls back to StreamAlertSettings.accentColor
  textColor   String? // label/secondary text color (null → default zinc)
  bgColor     String? // card background (null → default translucent dark)
  fontFamily  String? // font value from lib/widget-fonts (null → Inter)
  sortOrder   Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type, active])
  @@index([tenantId])
  @@index([tenantId, active]) // hot: active goals for a portal (incrementGoals, overlay feed) #perf
  @@map("stream_goals")
}

// =====================================================
// HYPE TRAIN — singleton state, populated by Twitch EventSub
// =====================================================

model HypeTrainState {
  id             String    @id @default(cuid()) // legacy singleton rows keep id "default"
  tenantId       String?   @unique // one hype-train state per tenant (null = legacy)
  active         Boolean   @default(false)
  level          Int       @default(0)
  goal           Int       @default(0) // points needed to reach next level
  total          Int       @default(0) // points already accumulated this train
  topContributor String? // user_name of top contributor
  startedAt      DateTime?
  expiresAt      DateTime? // when this train auto-ends if no further contributions
  endedAt        DateTime?
  updatedAt      DateTime  @updatedAt

  @@map("hype_train_state")
}

// =====================================================
// YOUTUBE LIVE CHAT — streamer token + event log
// Powers super chat detection + member events during live broadcasts.
// =====================================================

model YouTubeStreamerToken {
  id             String   @id @default(cuid()) // legacy singleton rows keep id "default"
  tenantId       String?  @unique // one streamer token per tenant (null = legacy)
  channelId      String // YouTube channel id (e.g. UCxxx)
  channelTitle   String?
  accessToken    String   @db.Text
  refreshToken   String   @db.Text // YouTube access tokens expire after 1h — refresh always required
  tokenExpiresAt DateTime
  scope          String // space-separated; should include youtube.readonly
  connectedAt    DateTime @default(now())
  connectedById  String? // admin user id who authorized

  // Polling state — admin / external cron updates these
  lastPolledAt       DateTime?
  currentLiveVideoId String? // most recently detected live broadcast videoId
  currentLiveChatId  String? // its liveChatId
  lastChatPageToken  String? // nextPageToken for liveChatMessages — incremental polling

  @@map("youtube_streamer_token")
}

model YouTubeEvent {
  id              String   @id @default(cuid())
  messageId       String   @unique // YouTube liveChat messageId — idempotency key
  videoId         String // which broadcast it came from
  type            String // "superChat" | "superSticker" | "newSponsor" | "memberMilestone" | "textMessage"
  authorChannelId String?
  authorName      String?
  message         String?  @db.Text
  amountMicros    BigInt? // for super chats: amount in micros (e.g. 1990000 = $1.99)
  currency        String?
  userId          String? // matched Ghost Empire user
  tokensGranted   Int?
  receivedAt      DateTime @default(now())

  @@index([type, receivedAt])
  @@index([videoId])
  @@map("youtube_events")
}

model StreamAlertSettings {
  id             String   @id @default(cuid()) // legacy singleton rows keep id "default"
  tenantId       String?  @unique // one settings row per tenant (null = legacy)
  enabledTypes   String[] @default(["shop_purchase", "event_win", "drop_claim_bonus", "twitch_sub", "twitch_gift_sub", "twitch_cheer", "donation", "welcome", "level_up", "test"])
  durationMs     Int      @default(6000)
  accentColor    String   @default("#E50914")
  soundEnabled   Boolean  @default(true)
  sizeScale      Float    @default(1) // overall alert size multiplier (0.5–2)
  textScale      Float    @default(1) // text size multiplier (0.5–2)
  textColor      String   @default("#d4d4d8") // message body text color
  hypeColor      String? // Hype Train accent (null → accentColor)
  hypeBgColor    String? // Hype Train banner background (null → default dark)
  hypeFontFamily String? // Hype Train font value from lib/widget-fonts (null → Inter)
  overlayToken   String? // auto-generated on first admin view; rotate via UI to invalidate OBS browser source URLs
  updatedAt      DateTime @updatedAt

  @@map("stream_alert_settings")
}

// GT sound redemptions: a streamer-defined catalog of sounds viewers can buy with
// GT to play on stream. A redemption spends GT and dispatches a "sound_redeem"
// alert carrying the soundUrl in its meta (the overlay plays it).
model SoundReward {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  emoji     String?
  cost      Int
  soundUrl  String // URL to the sound file (same as per-type alert sounds)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([tenantId, active])
  @@map("sound_rewards")
}

// =====================================================
// PAYMENT METHODS (#514) — the streamer's real-money "support/tip" methods shown
// on the public /support page (donatr.ee-style). Per-tenant + additive. Three kinds:
//   "link"   — value = an https URL (PayPal, Ko-fi, Patreon, Boosty, …)
//   "crypto" — value = a wallet address; `network` = BTC/ETH/USDT/SOL/… (one-tap copy + QR)
//   "bank"   — value = IBAN; `network` = account holder name (masked, reveal-on-click, SEPA-QR)
// =====================================================
model PaymentMethod {
  id        String   @id @default(cuid())
  tenantId  String?
  kind      String // "link" | "crypto" | "bank"
  label     String // display name, e.g. "PayPal", "Bitcoin", "Bank (PLN)"
  value     String   @db.Text // URL | wallet address | IBAN
  network   String? // crypto symbol/network (BTC/ETH/USDT…) OR bank account-holder name
  note      String? // optional sub-label shown under the method
  icon      String? // optional emoji
  featured  Boolean  @default(false) // highlighted as the recommended method
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  clicks    Int      @default(0) // # of times opened/copied on /support (#541, directional)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, active])
  @@map("payment_methods")
}

// =====================================================
// SPONSORS (#538) — per-portal brand partners shown on /support + an OBS strip.
// Additive + per-tenant. Public reads graceful-degrade before the table exists.
// =====================================================
model Sponsor {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String // sponsor / partner name, e.g. "HyperX"
  url       String   @db.Text // link to the sponsor
  logoUrl   String?  @db.Text // optional logo image URL
  note      String? // optional tagline, e.g. "Official gear partner"
  tier      String? // optional label, e.g. "Gold", "Partner"
  featured  Boolean  @default(false)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, active])
  @@map("sponsors")
}

// =====================================================
// OVERLAY SCENES (#550) — a saved multi-widget layout composited as one OBS source.
// `elements` is a JSON array of { id, widget, x, y, w, h } (percentages). Per-tenant.
// =====================================================
model OverlayScene {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  elements  String   @db.Text // JSON: [{ id, widget, x, y, w, h }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("overlay_scenes")
}

// =====================================================
// COLLECTIBLES (#551) — per-portal trading cards. Earned from GT "packs"; the
// tradeable asset that the P2P marketplace (#552) sits on top of. Per-tenant catalog
// + per-user ownership (qty). Additive.
// =====================================================
model Collectible {
  id          String  @id @default(cuid())
  tenantId    String?
  name        String
  description String? @db.Text
  rarity      String  @default("common") // common | rare | epic | legendary
  emoji       String? @default("🃏")
  imageUrl    String? @db.Text
  active      Boolean @default(true)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())

  owners   UserCollectible[]
  listings CardListing[]

  @@index([tenantId, active])
  @@map("collectibles")
}

model UserCollectible {
  id            String   @id @default(cuid())
  userId        String
  collectibleId String
  qty           Int      @default(1)
  acquiredAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectible Collectible @relation(fields: [collectibleId], references: [id], onDelete: Cascade)

  @@unique([userId, collectibleId])
  @@index([userId])
  @@index([collectibleId])
  @@index([userId, acquiredAt]) // owned cards newest-first (collection + /market picker) #perf
  @@map("user_collectibles")
}

// =====================================================
// CARD MARKETPLACE (#552) — P2P listings of owned collectibles for GT. The card is
// escrowed (removed from the seller's collection) while listed; on buy it moves to the
// buyer and GT moves seller-ward (minus a burned fee = GT sink). Per-tenant.
// =====================================================
model CardListing {
  id            String    @id @default(cuid())
  tenantId      String?
  sellerId      String
  collectibleId String
  price         Int // GT
  status        String    @default("active") // active | sold | cancelled
  buyerId       String? // plain ref (no relation — avoids a 2nd User<->CardListing edge)
  createdAt     DateTime  @default(now())
  closedAt      DateTime?

  seller      User        @relation("CardSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  collectible Collectible @relation(fields: [collectibleId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([sellerId])
  @@map("card_listings")
}

// =====================================================
// AI CLIP DIRECTOR (#517) — detect a chat hype spike → auto-create a Twitch clip.
// Per-tenant + additive. Dormant until enabled AND the streamer's Twitch token has
// the `clips:edit` scope (otherwise clip creation no-ops gracefully).
// =====================================================
model ClipDirectorConfig {
  id          String   @id @default(cuid())
  tenantId    String?  @unique
  enabled     Boolean  @default(false)
  threshold   Int      @default(10) // chat messages within the window to count as a hype spike
  windowSec   Int      @default(8)
  cooldownSec Int      @default(120) // minimum seconds between auto-clips
  updatedAt   DateTime @updatedAt

  @@map("clip_director_config")
}

model AutoClip {
  id        String   @id @default(cuid())
  tenantId  String?
  clipId    String // Twitch clip id
  editUrl   String   @db.Text
  title     String?
  reason    String? // "hype" | "manual"
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@map("auto_clips")
}

// =====================================================
// SUPPORT GOAL (#519) — a manually-tracked real-money fundraising goal shown on the
// public /support page (donatr.ee-style "cel zbiórki"). One per portal; the streamer
// sets the title/target and bumps the collected amount by hand.
// =====================================================
model SupportGoal {
  id        String   @id @default(cuid())
  tenantId  String?  @unique
  title     String // "New streaming PC", "Charity stream", …
  target    Int // goal amount (whole currency units)
  current   Int      @default(0) // collected so far (manually updated)
  currency  String   @default("PLN")
  active    Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("support_goals")
}

// =====================================================
// WEB PUSH (#533) — browser push subscriptions (one row per browser endpoint).
// Additive + per-tenant. Sends are VAPID-gated (dormant until keys + this table
// exist). Distinct from the in-app Notification model — this is the delivery channel.
// =====================================================
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String? // multi-tenant; null = legacy/founder
  endpoint  String   @unique // the browser push endpoint — natural key (re-subscribe upserts)
  p256dh    String // client public key (for payload encryption)
  auth      String // client auth secret
  userAgent String? // for the user to recognize a device in a future manage-UI
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("push_subscriptions")
}

// =====================================================
// TRIVIA / QUIZ (#523) — a per-portal question bank; viewers answer for GT (one
// attempt per question). Additive + per-tenant.
// =====================================================
model TriviaQuestion {
  id           String   @id @default(cuid())
  tenantId     String?
  question     String   @db.Text
  options      String[] // 2–6 answer options
  correctIndex Int // index into options
  reward       Int      @default(100) // GT for a correct answer
  category     String? // optional grouping/label
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  // Live round (#524): the streamer puts ONE question "live" on the OBS overlay with a
  // countdown; the correct answer is revealed on the overlay once liveEndsAt passes.
  live         Boolean   @default(false)
  liveEndsAt   DateTime?
  createdAt    DateTime @default(now())

  answers TriviaAnswer[]

  @@index([tenantId, active])
  @@map("trivia_questions")
}

model TriviaAnswer {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  optionIndex Int
  correct     Boolean
  createdAt   DateTime @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  question TriviaQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId]) // one attempt per question
  @@index([questionId])
  @@map("trivia_answers")
}

// =====================================================
// ALERT TYPE CONFIG — per-alert-type overrides for the OBS overlay.
// A type with NO row falls back to the overlay defaults (slide / bottom-right /
// synthesized ding / no threshold) — so unconfigured types look exactly as before.
// =====================================================
model AlertTypeConfig {
  id        String   @id @default(cuid())
  tenantId  String? // multi-tenant (#512) — per-portal alert-type styling
  type      String // matches AlertType in lib/alerts.ts — unique PER TENANT (was globally @unique)
  animation String   @default("slide") // slide | fade | scale | none
  position  String   @default("bottom-right") // {top|center|bottom}-{left|center|right}
  soundUrl  String? // custom sound URL; null = synthesized ding
  minAmount Int? // only show alert if amount >= this (null = always)
  updatedAt DateTime @updatedAt

  @@unique([tenantId, type])
  @@index([tenantId])
  @@map("alert_type_config")
}

// =====================================================
// STREAM CODES — pool of giveaway codes (e.g. game keys) displayed one-at-a-time
// on the /overlay/codes OBS source, rotating every CodeDropConfig.intervalSeconds.
// =====================================================

model StreamCode {
  id          String    @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection (code is NOT unique — a pool)
  code        String // the actual key/code shown on stream
  label       String? // e.g. "Cyberpunk 2077 (Steam)"
  active      Boolean   @default(true) // inactive codes are skipped in rotation
  shownCount  Int       @default(0) // how many times it has been displayed
  lastShownAt DateTime? // last time it rotated onto the overlay
  createdAt   DateTime  @default(now())

  @@index([active, shownCount])
  @@index([tenantId])
  @@map("stream_codes")
}

model CodeDropConfig {
  id              String    @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId        String?   @unique // multi-tenant (Phase 3)
  enabled         Boolean   @default(false)
  intervalSeconds Int       @default(600) // rotate the displayed code every N seconds
  title           String    @default("Darmowy kod!") // heading shown above the code
  accentColor     String    @default("#10b981")
  currentCodeId   String? // which code is on screen right now
  currentShownAt  DateTime? // when it was put on screen (drives rotation)
  updatedAt       DateTime  @updatedAt

  @@map("code_drop_config")
}

// =====================================================
// POLLS — simple community polls / votes (no tokens, free voting).
// Managed in /admin#polls, shown on /polls. One vote per user (changeable).
// =====================================================

model Poll {
  id          String    @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection (many rows/tenant, NOT unique)
  question    String    @db.Text
  options     String[] // option labels (order = optionIndex)
  status      String    @default("open") // "open" | "closed"
  accentColor String    @default("#3b82f6") // card accent (hex) on /polls
  createdById String?
  createdAt   DateTime  @default(now())
  closesAt    DateTime?

  votes PollVote[]

  @@index([status, createdAt])
  @@index([tenantId])
  @@map("polls")
}

model PollVote {
  id          String   @id @default(cuid())
  pollId      String
  userId      String
  optionIndex Int
  createdAt   DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId, optionIndex])
  @@map("poll_votes")
}

// =====================================================
// CHAT OVERLAY CONFIG — singleton; styles the /overlay/chat OBS source.
// Edited in /admin#chat, applied live by the overlay + the in-panel preview.
// =====================================================

model ChatOverlayConfig {
  id               String   @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId         String?  @unique // multi-tenant (Phase 3)
  fontSize         Int      @default(15) // message text size (px)
  textColor        String   @default("#e4e4e7") // message body color
  fontFamily       String   @default("Inter") // "Inter" | "JetBrains Mono" | "Anton" | "system"
  bgOpacity        Float    @default(0.85) // 0..1 — message bubble background darkness
  showPlatformIcon Boolean  @default(true) // 🟣🟢🔴 platform dot before the name
  updatedAt        DateTime @updatedAt

  @@map("chat_overlay_config")
}

// =====================================================
// CUSTOM ALERTS — admin-defined alert templates. Fired manually into the
// StreamAlert queue → shown on the /overlay OBS source. Managed in /admin#alerts.
// =====================================================

model CustomAlert {
  id          String   @id @default(cuid())
  tenantId    String? // multi-tenant (#512) — each portal has its own custom alerts
  label       String // admin-facing name (list)
  title       String // heading shown on the overlay
  message     String // body shown on the overlay
  icon        String?  @default("🔔")
  accent      String? // optional per-alert accent color (else global)
  amount      Int? // optional number badge
  amountLabel String? // e.g. "GT" / "PLN"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("custom_alerts")
}

// =====================================================
// CUSTOM WIDGETS — user-built text overlays (the "widget generator"). Each gets a
// token-gated /overlay/widget?id= URL. Supports emoji / Unicode in the text.
// =====================================================
model CustomWidget {
  id          String   @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 4 overlay pass); null = legacy
  name        String // admin-facing label
  text        String   @db.Text // displayed text (emoji/Unicode ok)
  accentColor String   @default("#E50914") // card border / accent
  textColor   String   @default("#ffffff")
  fontSizePx  Int      @default(28)
  fontFamily  String   @default("Inter") // Inter | JetBrains Mono | Anton | system
  position    String   @default("top-left") // {top|center|bottom}-{left|center|right}
  showCard    Boolean  @default(true) // card background vs bare text
  bgGradient  Boolean  @default(false) // when showCard: gradient background instead of dark card
  bgColor1    String   @default("#7928ca") // gradient stop 1 (hex)
  bgColor2    String   @default("#ff0080") // gradient stop 2 (hex)
  bgAngle     Int      @default(135) // gradient angle in degrees (0-360)
  posXPct     Int? // free drag position (0-100% of screen); null = use `position` slot
  posYPct     Int?
  scalePct    Int? // free resize (25-300% of natural size); null = 100%
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("custom_widgets")
}

// =====================================================
// EMOJI COMBO — singleton bridge: the bot detects an emoji combo in chat and POSTs
// it here; the /overlay/emoji-combo OBS source reads it (active only if fresh).
// =====================================================
model EmojiComboState {
  id        String   @id @default(cuid()) // legacy singleton rows keep id "default"
  tenantId  String?  @unique // one combo state per tenant (null = legacy)
  emoji     String   @default("")
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("emoji_combo_state")
}

// =====================================================
// INTEGRATION CONFIG — runtime/feature API keys pasted in /admin#integrations
// (admin-only). Read at runtime via lib/integrations.ts (DB value overrides env).
// Infra/auth secrets (DATABASE_URL, NEXTAUTH_SECRET, OAuth login, BOT_SECRET) stay
// in env — they bootstrap the app and must not live in the DB.
// =====================================================
model IntegrationConfig {
  id         String  @id @default(cuid()) // was @default("default") singleton; now one row per tenant
  aiProvider String  @default("anthropic") // anthropic | openai | grok | gemini | deepseek | bielik
  aiApiKey   String? // key for the AI character + !imagine (F4)
  aiModel    String? // optional model override

  sentryDsn            String? // error monitoring DSN
  obsWebsocketUrl      String? // ws://host:port for OBS control
  obsWebsocketPassword String?
  recapDiscordWebhook  String? // Discord webhook URL for AI stream recaps (#516)

  goveeApiKey      String? // per-tenant Govee cloud Developer API key (encrypted at rest) (#720)
  goveeDeviceId    String? // Govee device id to control
  goveeDeviceModel String? // Govee device model (e.g. H6159)

  tenantId String? @unique // multi-tenant (Phase 3): one config row per tenant

  updatedAt DateTime @updatedAt

  @@map("integration_config")
}

// PHASE 3C — OBS WebSocket control: a per-tenant rule mapping a StreamAlert event
// (triggerType + optional minAmount) to an OBS action. Pure matching/validation lives
// in lib/obs-rules.ts; the in-OBS browser-source controller (later slice) actuates.
// Dormant until a streamer adds the controller source + OBS WebSocket creds.
model ObsRule {
  id            String   @id @default(cuid())
  tenantId      String? // multi-tenant — per-portal; null = legacy
  enabled       Boolean  @default(true)
  triggerType   String // StreamAlert.type, or "*" for any
  minAmount     Int? // only fire when alert.amount >= this
  actionKind    String // switch_scene | toggle_source | toggle_filter
  scene         String? // switch_scene target / toggle_source owning scene
  source        String? // toggle_source / toggle_filter source name
  filter        String? // toggle_filter filter name
  targetState   Boolean? // toggle_source visible / toggle_filter enabled
  revertAfterMs Int? // optional auto-revert window (ms)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, triggerType])
  @@map("obs_rules")
}

// Per-tenant Govee lighting rules (#720): a StreamAlert event -> a Govee light action.
// Mirrors ObsRule (flattened action columns). Pure logic + validation in lib/govee-rules.ts;
// the server-side actuator in lib/govee.ts reads these + the tenant's Govee creds (in
// IntegrationConfig) and calls the Govee cloud API. Dormant until creds + rules exist.
model GoveeRule {
  id            String   @id @default(cuid())
  tenantId      String? // multi-tenant — per-portal; null = legacy/founder
  enabled       Boolean  @default(true)
  triggerType   String // StreamAlert.type, or "*" for any
  minAmount     Int? // only fire when alert.amount >= this
  actionKind    String // set_color | set_brightness | turn
  color         String? // set_color hex (#rrggbb)
  revertColor   String? // set_color flash → rest hex (optional)
  brightness    Int? // set_brightness 0-100
  turnOn        Boolean? // turn on/off
  revertAfterMs Int? // optional auto-revert window (ms)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, triggerType])
  @@map("govee_rules")
}

// Viewer Bounties (#679): viewers pool GT to challenge the streamer to do something on
// stream. Pledges ESCROW GT (deducted at pledge time). On "completed" the pool is kept —
// burned, a GT sink, the viewers got the action; on "rejected"/"expired" every pledge is
// refunded. Resolved by the streamer (admin). Mirrors the predictions escrow pattern.
model Bounty {
  id          String    @id @default(cuid())
  tenantId    String? // per-portal
  creatorId   String
  title       String // the challenge
  description String?
  status      String    @default("open") // open | completed | rejected | expired
  pooledGt    Int       @default(0) // total GT escrowed across all pledges
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  creator User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  pledges BountyPledge[]

  @@index([tenantId, status, createdAt])
  @@index([creatorId])
  @@map("bounties")
}

model BountyPledge {
  id        String   @id @default(cuid())
  bountyId  String
  userId    String
  amount    Int
  createdAt DateTime @default(now())

  bounty Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bountyId])
  @@index([userId])
  @@map("bounty_pledges")
}

// Prediction League (#682): a recorded month-end podium + GT prize. One row per
// (portal, season, user); the unique makes settlement idempotent. Powers the Hall of Fame.
model LeagueSeasonResult {
  id           String   @id @default(cuid())
  tenantId     String? // per-portal (null = founder/legacy)
  seasonNumber Int // months since 2026-01 (matches seasons.monthBounds)
  seasonLabel  String // e.g. "Maj 2026"
  userId       String
  rank         Int // 1-based finishing position
  net          Int // net GT that season (winnings minus stakes)
  wins         Int
  plays        Int
  prize        Int // GT awarded (0 if Hall-of-Fame-only)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, seasonNumber, userId])
  @@index([tenantId, seasonNumber, rank])
  @@map("league_season_results")
}
