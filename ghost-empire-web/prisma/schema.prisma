  broadcasterId    String // Kick user_id (numeric, stored as string)
  broadcasterLogin String // Kick username/slug for display
  accessToken      String    @db.Text
  refreshToken     String?   @db.Text
  tokenExpiresAt   DateTime?
  scope            String // space-separated scopes granted
  connectedAt      DateTime  @default(now())
  connectedById    String? // admin user id who authorized

  @@index([broadcasterId]) // webhook events carry broadcaster id → tenant lookup
  @@map("kick_streamer_token")
}

model KickEventSubscription {
  id            String    @id // Kick's subscription id
  type          String // "chat.message.sent" | "channel.subscription.new" | "channel.subscription.gifts" | ...
  broadcasterId String
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime?

  @@index([type])
  @@map("kick_event_subscriptions")
}

model KickEvent {
  id            String   @id @default(cuid())
  eventId       String   @unique // Kick message_id for idempotency
  type          String
  payload       String   @db.Text // JSON of full event
  userId        String? // matched Ghost Empire user
  tokensGranted Int?
  receivedAt    DateTime @default(now())

  @@index([type, receivedAt])
  @@map("kick_events")
}

// =====================================================
// PREDICTIONS / BETS — viewers wager Ghost Tokens on outcomes
// =====================================================

model Prediction {
  id                  String    @id @default(cuid())
  tenantId            String? // multi-tenant (Phase 3) — collection (many rows/tenant, NOT unique)
  question            String    @db.Text
  options             String[] // labels for each option, order matches optionIndex
  status              String    @default("open") // "open" | "locked" | "resolved" | "cancelled"
  resolvedOptionIndex Int? // null until resolved
  totalPot            Int       @default(0) // sum of all wagers across all options
  opensAt             DateTime  @default(now())
  closesAt            DateTime? // wagers blocked after this (and status auto-flips to "locked")
  resolvedAt          DateTime?
  announceToChat      Boolean   @default(true) // bot re-announces this bet in chat while open
  accentColor         String    @default("#a855f7") // card accent (hex) on /predictions + overlay
  createdById         String? // admin user id
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  entries PredictionEntry[]

  @@index([status, opensAt])
  @@index([tenantId])
  @@map("predictions")
}

model PredictionEntry {
  id            String   @id @default(cuid())
  predictionId  String
  userId        String
  optionIndex   Int // which option they bet on
  tokensWagered Int // positive — deducted from User.tokens at wager time
  payout        Int      @default(0) // set on resolve; 0 if losing option
  wageredAt     DateTime @default(now())

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  @@unique([predictionId, userId]) // one wager per user per prediction
  @@index([userId])
  @@map("prediction_entries")
}

// =====================================================
// STREAM GOALS — visible progress bars on OBS overlay
// Auto-incremented when EventSub / Streamlabs handlers fire matching events.
// =====================================================

model StreamGoal {
  id          String    @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection (many rows/tenant, NOT unique)
  type        String // "subs" | "follows" | "donations_pln" | "cheers_bits" | "gift_subs" | "yt_members"
  label       String // admin custom text shown on overlay e.g. "500 subów = nowy setup!"
  current     Int       @default(0)
  target      Int
  active      Boolean   @default(true)
  resetMode   String    @default("manual") // "manual" | "per_stream" | "daily" | "weekly" | "monthly"
  lastResetAt DateTime?
  color       String? // overlay accent override; falls back to StreamAlertSettings.accentColor
  textColor   String? // label/secondary text color (null → default zinc)
  bgColor     String? // card background (null → default translucent dark)
  fontFamily  String? // font value from lib/widget-fonts (null → Inter)
  sortOrder   Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type, active])
  @@index([tenantId])
  @@map("stream_goals")
}

// =====================================================
// HYPE TRAIN — singleton state, populated by Twitch EventSub
// =====================================================

model HypeTrainState {
  id             String    @id @default(cuid()) // legacy singleton rows keep id "default"
  tenantId       String?   @unique // one hype-train state per tenant (null = legacy)
  active         Boolean   @default(false)
  level          Int       @default(0)
  goal           Int       @default(0) // points needed to reach next level
  total          Int       @default(0) // points already accumulated this train
  topContributor String? // user_name of top contributor
  startedAt      DateTime?
  expiresAt      DateTime? // when this train auto-ends if no further contributions
  endedAt        DateTime?
  updatedAt      DateTime  @updatedAt

  @@map("hype_train_state")
}

// =====================================================
// YOUTUBE LIVE CHAT — streamer token + event log
// Powers super chat detection + member events during live broadcasts.
// =====================================================

model YouTubeStreamerToken {
  id             String   @id @default(cuid()) // legacy singleton rows keep id "default"
  tenantId       String?  @unique // one streamer token per tenant (null = legacy)
  channelId      String // YouTube channel id (e.g. UCxxx)
  channelTitle   String?
  accessToken    String   @db.Text
  refreshToken   String   @db.Text // YouTube access tokens expire after 1h — refresh always required
  tokenExpiresAt DateTime
  scope          String // space-separated; should include youtube.readonly
  connectedAt    DateTime @default(now())
  connectedById  String? // admin user id who authorized

  // Polling state — admin / external cron updates these
  lastPolledAt       DateTime?
  currentLiveVideoId String? // most recently detected live broadcast videoId
  currentLiveChatId  String? // its liveChatId
  lastChatPageToken  String? // nextPageToken for liveChatMessages — incremental polling

  @@map("youtube_streamer_token")
}

model YouTubeEvent {
  id              String   @id @default(cuid())
  messageId       String   @unique // YouTube liveChat messageId — idempotency key
  videoId         String // which broadcast it came from
  type            String // "superChat" | "superSticker" | "newSponsor" | "memberMilestone" | "textMessage"
  authorChannelId String?
  authorName      String?
  message         String?  @db.Text
  amountMicros    BigInt? // for super chats: amount in micros (e.g. 1990000 = $1.99)
  currency        String?
  userId          String? // matched Ghost Empire user
  tokensGranted   Int?
  receivedAt      DateTime @default(now())

  @@index([type, receivedAt])
  @@index([videoId])
  @@map("youtube_events")
}

model StreamAlertSettings {
  id             String   @id @default(cuid()) // legacy singleton rows keep id "default"
  tenantId       String?  @unique // one settings row per tenant (null = legacy)
  enabledTypes   String[] @default(["shop_purchase", "event_win", "drop_claim_bonus", "twitch_sub", "twitch_gift_sub", "twitch_cheer", "donation", "welcome", "level_up", "test"])
  durationMs     Int      @default(6000)
  accentColor    String   @default("#E50914")
  soundEnabled   Boolean  @default(true)
  sizeScale      Float    @default(1) // overall alert size multiplier (0.5–2)
  textScale      Float    @default(1) // text size multiplier (0.5–2)
  textColor      String   @default("#d4d4d8") // message body text color
  hypeColor      String? // Hype Train accent (null → accentColor)
  hypeBgColor    String? // Hype Train banner background (null → default dark)
  hypeFontFamily String? // Hype Train font value from lib/widget-fonts (null → Inter)
  overlayToken   String? // auto-generated on first admin view; rotate via UI to invalidate OBS browser source URLs
  updatedAt      DateTime @updatedAt

  @@map("stream_alert_settings")
}

// GT sound redemptions: a streamer-defined catalog of sounds viewers can buy with
// GT to play on stream. A redemption spends GT and dispatches a "sound_redeem"
// alert carrying the soundUrl in its meta (the overlay plays it).
model SoundReward {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  emoji     String?
  cost      Int
  soundUrl  String // URL to the sound file (same as per-type alert sounds)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([tenantId, active])
  @@map("sound_rewards")
}

// =====================================================
// PAYMENT METHODS (#514) — the streamer's real-money "support/tip" methods shown
// on the public /support page (donatr.ee-style). Per-tenant + additive. Three kinds:
//   "link"   — value = an https URL (PayPal, Ko-fi, Patreon, Boosty, …)
//   "crypto" — value = a wallet address; `network` = BTC/ETH/USDT/SOL/… (one-tap copy + QR)
//   "bank"   — value = IBAN; `network` = account holder name (masked, reveal-on-click, SEPA-QR)
// =====================================================
model PaymentMethod {
  id        String   @id @default(cuid())
  tenantId  String?
  kind      String // "link" | "crypto" | "bank"
  label     String // display name, e.g. "PayPal", "Bitcoin", "Bank (PLN)"
  value     String   @db.Text // URL | wallet address | IBAN
  network   String? // crypto symbol/network (BTC/ETH/USDT…) OR bank account-holder name
  note      String? // optional sub-label shown under the method
  icon      String? // optional emoji
  featured  Boolean  @default(false) // highlighted as the recommended method
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, active])
  @@map("payment_methods")
}

// =====================================================
// ALERT TYPE CONFIG — per-alert-type overrides for the OBS overlay.
// A type with NO row falls back to the overlay defaults (slide / bottom-right /
// synthesized ding / no threshold) — so unconfigured types look exactly as before.
// =====================================================
model AlertTypeConfig {
  id        String   @id @default(cuid())
  tenantId  String? // multi-tenant (#512) — per-portal alert-type styling
  type      String // matches AlertType in lib/alerts.ts — unique PER TENANT (was globally @unique)
  animation String   @default("slide") // slide | fade | scale | none
  position  String   @default("bottom-right") // {top|center|bottom}-{left|center|right}
  soundUrl  String? // custom sound URL; null = synthesized ding
  minAmount Int? // only show alert if amount >= this (null = always)
  updatedAt DateTime @updatedAt

  @@unique([tenantId, type])
  @@index([tenantId])
  @@map("alert_type_config")
}

// =====================================================
// STREAM CODES — pool of giveaway codes (e.g. game keys) displayed one-at-a-time
// on the /overlay/codes OBS source, rotating every CodeDropConfig.intervalSeconds.
// =====================================================

model StreamCode {
  id          String    @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection (code is NOT unique — a pool)
  code        String // the actual key/code shown on stream
  label       String? // e.g. "Cyberpunk 2077 (Steam)"
  active      Boolean   @default(true) // inactive codes are skipped in rotation
  shownCount  Int       @default(0) // how many times it has been displayed
  lastShownAt DateTime? // last time it rotated onto the overlay
  createdAt   DateTime  @default(now())

  @@index([active, shownCount])
  @@index([tenantId])
  @@map("stream_codes")
}

model CodeDropConfig {
  id              String    @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId        String?   @unique // multi-tenant (Phase 3)
  enabled         Boolean   @default(false)
  intervalSeconds Int       @default(600) // rotate the displayed code every N seconds
  title           String    @default("Darmowy kod!") // heading shown above the code
  accentColor     String    @default("#10b981")
  currentCodeId   String? // which code is on screen right now
  currentShownAt  DateTime? // when it was put on screen (drives rotation)
  updatedAt       DateTime  @updatedAt

  @@map("code_drop_config")
}

// =====================================================
// POLLS — simple community polls / votes (no tokens, free voting).
// Managed in /admin#polls, shown on /polls. One vote per user (changeable).
// =====================================================

model Poll {
  id          String    @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection (many rows/tenant, NOT unique)
  question    String    @db.Text
  options     String[] // option labels (order = optionIndex)
  status      String    @default("open") // "open" | "closed"
  accentColor String    @default("#3b82f6") // card accent (hex) on /polls
  createdById String?
  createdAt   DateTime  @default(now())
  closesAt    DateTime?

  votes PollVote[]

  @@index([status, createdAt])
  @@index([tenantId])
  @@map("polls")
}

model PollVote {
  id          String   @id @default(cuid())
  pollId      String
  userId      String
  optionIndex Int
  createdAt   DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId, optionIndex])
  @@map("poll_votes")
}

// =====================================================
// CHAT OVERLAY CONFIG — singleton; styles the /overlay/chat OBS source.
// Edited in /admin#chat, applied live by the overlay + the in-panel preview.
// =====================================================

model ChatOverlayConfig {
  id               String   @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId         String?  @unique // multi-tenant (Phase 3)
  fontSize         Int      @default(15) // message text size (px)
  textColor        String   @default("#e4e4e7") // message body color
  fontFamily       String   @default("Inter") // "Inter" | "JetBrains Mono" | "Anton" | "system"
  bgOpacity        Float    @default(0.85) // 0..1 — message bubble background darkness
  showPlatformIcon Boolean  @default(true) // 🟣🟢🔴 platform dot before the name
  updatedAt        DateTime @updatedAt

  @@map("chat_overlay_config")
}

// =====================================================
// CUSTOM ALERTS — admin-defined alert templates. Fired manually into the
// StreamAlert queue → shown on the /overlay OBS source. Managed in /admin#alerts.
// =====================================================

model CustomAlert {
  id          String   @id @default(cuid())
  tenantId    String? // multi-tenant (#512) — each portal has its own custom alerts
  label       String // admin-facing name (list)
  title       String // heading shown on the overlay
  message     String // body shown on the overlay
  icon        String?  @default("🔔")
  accent      String? // optional per-alert accent color (else global)
  amount      Int? // optional number badge
  amountLabel String? // e.g. "GT" / "PLN"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("custom_alerts")
}

// =====================================================
// CUSTOM WIDGETS — user-built text overlays (the "widget generator"). Each gets a
// token-gated /overlay/widget?id= URL. Supports emoji / Unicode in the text.
// =====================================================
model CustomWidget {
  id          String   @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 4 overlay pass); null = legacy
  name        String // admin-facing label
  text        String   @db.Text // displayed text (emoji/Unicode ok)
  accentColor String   @default("#E50914") // card border / accent
  textColor   String   @default("#ffffff")
  fontSizePx  Int      @default(28)
  fontFamily  String   @default("Inter") // Inter | JetBrains Mono | Anton | system
  position    String   @default("top-left") // {top|center|bottom}-{left|center|right}
  showCard    Boolean  @default(true) // card background vs bare text
  bgGradient  Boolean  @default(false) // when showCard: gradient background instead of dark card
  bgColor1    String   @default("#7928ca") // gradient stop 1 (hex)
  bgColor2    String   @default("#ff0080") // gradient stop 2 (hex)
  bgAngle     Int      @default(135) // gradient angle in degrees (0-360)
  posXPct     Int? // free drag position (0-100% of screen); null = use `position` slot
  posYPct     Int?
  scalePct    Int? // free resize (25-300% of natural size); null = 100%
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("custom_widgets")
}

// =====================================================
// EMOJI COMBO — singleton bridge: the bot detects an emoji combo in chat and POSTs
// it here; the /overlay/emoji-combo OBS source reads it (active only if fresh).
// =====================================================
model EmojiComboState {
  id        String   @id @default(cuid()) // legacy singleton rows keep id "default"
  tenantId  String?  @unique // one combo state per tenant (null = legacy)
  emoji     String   @default("")
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("emoji_combo_state")
}

// =====================================================
// INTEGRATION CONFIG — runtime/feature API keys pasted in /admin#integrations
// (admin-only). Read at runtime via lib/integrations.ts (DB value overrides env).
// Infra/auth secrets (DATABASE_URL, NEXTAUTH_SECRET, OAuth login, BOT_SECRET) stay
// in env — they bootstrap the app and must not live in the DB.
// =====================================================
model IntegrationConfig {
  id         String  @id @default(cuid()) // was @default("default") singleton; now one row per tenant
  aiProvider String  @default("anthropic") // anthropic | openai | grok | gemini | deepseek | bielik
  aiApiKey   String? // key for the AI character + !imagine (F4)
  aiModel    String? // optional model override

  sentryDsn            String? // error monitoring DSN
  obsWebsocketUrl      String? // ws://host:port for OBS control
  obsWebsocketPassword String?
  recapDiscordWebhook  String? // Discord webhook URL for AI stream recaps (#516)

  tenantId String? @unique // multi-tenant (Phase 3): one config row per tenant

  updatedAt DateTime @updatedAt

  @@map("integration_config")
}
