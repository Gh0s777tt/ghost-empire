// prisma/schema.prisma
// Ghost Empire - Full Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================================
// TENANCY (multi-tenant SaaS — Phase 1 scaffold)
// =====================================================
// One row per streamer/customer. Phase 1 introduces the model + User.tenantId
// (nullable, backfilled to the default tenant). Later phases scope the remaining
// models, resolve the tenant from the request subdomain, and make tenantId
// required once every row is attributed.

model Tenant {
  id                   String    @id @default(cuid())
  slug                 String    @unique // subdomain + URL key, e.g. "ghost-empire"
  name                 String // brand display name, e.g. "GH0ST EMPIRE"
  shortName            String? // manifest short_name / compact UI
  brandColor           String    @default("#E50914")
  logoUrl              String?
  domain               String? // optional custom domain
  // White-label currency naming (Phase 5): i18n catalogs carry %tokenName%/%gt%
  // markers that the message loader replaces with these per-tenant values.
  tokenName            String    @default("Ghost Tokens") // full currency name, e.g. "Neo Coins"
  tokenSymbol          String    @default("GT") // short unit shown next to amounts
  ownerHandle          String? // streamer's public handle (%owner% in i18n), e.g. "Gh0s77tt"
  // Phase 6 — billing/entitlements. The founder tenant defaults to "elite" so the
  // existing portal never gates itself; paying tenants get their plan at checkout.
  plan                 String    @default("elite") // "basic" | "pro" | "elite"
  planExpiresAt        DateTime? // null = never (founder); past date = expired → basic features
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  ownerUserId          String? // streamer-admin who owns this tenant (plain ref — no relation, to avoid a second User<->Tenant edge)
  ownerEmail           String? // owner's login email — first sign-in on the tenant's subdomain with this email gets isAdmin (Phase 6 onboarding)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Phase 3 will scope the remaining models; User is the anchor relation.
  users     User[]
  // Viewers who follow this portal (cross-portal "switch streamers" hub, #508).
  followers PortalFollow[]

  @@map("tenants")
}

// =====================================================
// STREAMER HUB (#508) — cross-portal follow + switch
// =====================================================
// A viewer "follows" a streamer's portal so it shows in their hub and they can
// jump between favorite portals from anywhere. Additive + non-breaking: built on
// the existing shared identity (one User per person), so it touches NO auth/account
// code. A row simply records "this user follows this tenant's portal".
model PortalFollow {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("portal_follows")
}

// =====================================================
// USER & AUTH
// =====================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  // Per-tenant identity (Stage C, #511): email is unique PER PORTAL, not globally —
  // the same person reuses one email across portals. See @@unique([email, tenantId]).
  email         String?
  emailVerified DateTime?
  image         String?

  // Identity
  username    String? @unique
  displayName String?
  bio         String?

  // Economy
  tokens      Int @default(0)
  totalEarned Int @default(0)
  totalSpent  Int @default(0)

  // Referrals — own shareable code + who invited this user (set once on claim)
  referralCode String? @unique
  referredById String?

  // Progression
  level          Int       @default(1)
  xp             Int       @default(0)
  prestige       Int       @default(0) // Phantom Ascension: +1 per PRESTIGE_XP of lifetime XP past the level cap (never resets)
  streak         Int       @default(0)
  lastStreakDate String? // "YYYY-MM-DD"
  lastDaily      DateTime?

  // Stats
  messageCount Int @default(0)
  voiceMinutes Int @default(0)

  // Security — opt-in TOTP step-up for sensitive admin actions.
  // totpSecret is encrypted at rest (lib/crypto); totpEnabledAt set once confirmed.
  totpSecret    String?
  totpEnabledAt DateTime?

  // Discord link
  discordId       String? @unique
  discordUsername String?

  // Admin & roles
  isAdmin        Boolean  @default(false)
  isModerator    Boolean  @default(false)
  isDonator      Boolean  @default(false)
  totalDonated   Int      @default(0) // suma donejtów (w jednostkach umownych, np. groszach)
  modNote        String? // notatka admina
  modPermissions String[] @default([]) // ["create_events","grant_tokens","ban_users","manage_shop","draw_events","mark_subs"]

  // Site-level ban/mute (independent of platform bans)
  isBanned    Boolean   @default(false)
  bannedUntil DateTime? // null = permanent
  banReason   String?

  // Tenancy (multi-tenant SaaS). Phase 1: nullable + backfilled to the default
  // tenant; a later phase makes it required once every row is scoped.
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // App relations
  connections      Connection[]
  transactions     Transaction[]
  userAchievements UserAchievement[]
  userTasks        UserTask[]
  socialLinks      SocialLink[]
  eventEntries     EventEntry[]
  raffleTickets    RaffleTicket[]
  notifications    Notification[]
  donations        Donation[]
  pollVotes        PollVote[]
  clipVotes        ClipVote[]
  portalFollows    PortalFollow[]
  wheelSpins       WheelSpin[]
  gtGamePlays      GtGamePlay[]
  duelsChallenged  Duel[]            @relation("DuelChallenger")
  duelsOpposed     Duel[]            @relation("DuelOpponent")
  duelsWon         Duel[]            @relation("DuelWinner")
  heistEntries     HeistEntry[]
  companion        Companion?
  clanId           String?
  clanRole         String? // "owner" | "member" within `clan`
  clan             Clan?             @relation("ClanMembers", fields: [clanId], references: [id])

  // Ranking + homepage top-users sort on these (DESC, filtered > 0). Indexes
  // turn full-table scan+sort into index range scans on free-tier Postgres.
  @@index([tokens])
  @@index([totalEarned])
  @@index([level, xp])
  @@index([streak])
  @@index([tenantId])
  @@index([clanId])
  @@index([referredById])
  // Per-tenant identity (Stage C, #511): email unique within a portal, not globally.
  // (username stays globally @unique — its sign-in collision handler covers dups.)
  @@unique([email, tenantId])
  @@map("users")
}

// Clip of the Week — community votes on the streamer's recent Twitch clips.
// One vote per user per ISO week (you pick your single favourite); changing it
// updates the row. Clips themselves come live from Helix (not stored).
model ClipVote {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String
  clipId    String // Twitch clip id
  week      String // ISO week key, e.g. "2026-W25"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, week]) // one vote per user per week
  @@index([tenantId, week])
  @@index([clipId])
  @@map("clip_votes")
}

// A per-user "Ghost Companion" — an idle pet that grows with fed GT and evolves
// through stages. Feeding BURNS GT out of circulation (a real economy sink, the
// counterpart to all the GT faucets). xp = lifetime GT fed; stage derived in
// lib/companion.ts. One per user (@unique), cascades on account delete.
model Companion {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String    @default("Widmo")
  xp        Int       @default(0)
  lastFedAt DateTime?
  tenantId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId])
  @@map("companions")
}

// A clan/team: viewers band together and pool GT into a shared treasury (a real
// economy SINK), then climb the clan leaderboard. One clan per user (User.clanId);
// `ownerUserId` is the founder (plain id used for permission checks, not a relation).
model Clan {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  tag         String
  ownerUserId String
  treasury    Int      @default(0)
  warPoints   Int      @default(0) // GT contributed during the ACTIVE clan war; reset when a new war starts
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     User[]   @relation("ClanMembers")

  @@unique([tenantId, tag])
  @@index([tenantId])
  @@index([treasury])
  @@index([warPoints])
  @@map("clans")
}

// A time-boxed clan war: clans earn `warPoints` (= GT members contribute during the
// window); the admin starts/ends it and the top clan wins the prize pool into its
// treasury. One active war per tenant at a time.
model ClanWar {
  id           String   @id @default(cuid())
  tenantId     String?
  name         String
  startsAt     DateTime @default(now())
  endsAt       DateTime
  status       String   @default("active") // "active" | "ended"
  prizePool    Int      @default(0) // GT awarded to the winner's treasury on resolve
  winnerClanId String?
  winnerTag    String?
  winnerPoints Int?
  createdAt    DateTime @default(now())

  @@index([tenantId, status])
  @@map("clan_wars")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  // Per-tenant identity (Stage A, #510): which portal this provider link belongs to.
  // Nullable + additive — backfilled from user.tenantId, then Stage C flips the unique
  // below to [provider, providerAccountId, tenantId] so one identity links once PER
  // tenant. NULL = legacy/pre-backfill (the tenant-aware adapter self-heals it).
  tenantId          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Stage C (#511): per-tenant — one provider identity links once PER portal. The
  // tenant-aware adapter (lib/auth-adapter.ts) scopes lookups by tenantId.
  @@unique([provider, providerAccountId, tenantId])
  @@index([tenantId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =====================================================
// PLATFORM CONNECTIONS
// =====================================================

model Connection {
  id          String  @id @default(cuid())
  userId      String
  platform    String // "twitch" | "kick" | "youtube" | "discord"
  platformId  String // user's ID on that platform
  username    String
  displayName String?
  avatar      String?

  // OAuth tokens (encrypted in production)
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  tokenExpiry  DateTime?

  // Sub status
  isSubscriber Boolean   @default(false)
  subTier      String? // "T1" | "T2" | "T3" | "Prime"
  subMonths    Int       @default(0)
  subStartDate DateTime?

  // Platform role (Twitch mod, Discord admin, Kick mod, etc.)
  isModerator Boolean @default(false) // mod na DANEJ platformie
  isVip       Boolean @default(false) // VIP na Twitch / equivalent
  isOG        Boolean @default(false) // Kick OG (original supporter)

  // Platform-side ban/mute (set by streamer/mods on tej platformie)
  isBanned  Boolean @default(false)
  isMuted   Boolean @default(false)
  banReason String?

  // Platform metrics
  bits       Int? // Twitch lifetime bits cheered
  kickPoints Int? // Kick channel points
  subCount   Int? // sub count of THIS user's channel (if streamer themselves)

  // Cached stats (updated via webhook/cron)
  followers Int?
  following Int?
  viewCount Int?

  connectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@unique([platform, platformId])
  // Webhook handlers (Twitch/Kick) look up the linked account by platform + username
  // on every sub/cheer/gift event — index the equality columns.
  @@index([platform, username])
  @@map("connections")
}

// =====================================================
// ECONOMY
// =====================================================

model Transaction {
  id     String @id @default(cuid())
  userId String

  type   String // "earn" | "spend" | "admin_grant" | "admin_deduct" | "refund"
  amount Int // positive = earn, negative = spend

  reason     String
  multiplier Float  @default(1.0)

  // External payment id (e.g. "paymedia:<payment_id>") — unique, so a concurrent
  // webhook retry loses with P2002 instead of double-crediting. NULL for
  // non-payment transactions (Postgres allows many NULLs in a unique column).
  externalId String? @unique

  // If purchase
  shopItemId String?
  shopItem   ShopItem? @relation(fields: [shopItemId], references: [id])

  // Delivery status (for physical/digital items)
  status String  @default("completed") // "pending" | "completed" | "delivered" | "refunded"
  note   String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Highest-write table (insert per chat message) — had ZERO indexes.
  // [userId, createdAt]: profile history + daily-bonus lookback.
  // [type, createdAt]: weekly-ranking groupBy + pending-orders + anomaly scan.
  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("transactions")
}

// =====================================================
// SHOP
// =====================================================

model ShopItem {
  id          String  @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection (many rows/tenant, NOT unique)
  name        String
  description String  @db.Text
  category    String // "games" | "skins" | "subs" | "cosmetic" | "experience"
  price       Int

  imageUrl   String?
  imageEmoji String? @default("🎁")

  stock      Int @default(-1) // -1 = unlimited
  totalStock Int @default(-1)

  hot      Boolean @default(false)
  active   Boolean @default(true)
  featured Boolean @default(false)

  // Requirements
  requiresSubTier     String? // "T1" | "T2" | "T3" | "DUAL"
  requiresMinLevel    Int?
  requiresMinMonths   Int?
  requiresAchievement String? // Achievement.code that must be earned to unlock this item

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]

  @@index([tenantId])
  @@map("shop_items")
}

// =====================================================
// EVENTS
// =====================================================

model Event {
  id          String  @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection (many rows/tenant, NOT unique)
  type        String // "giveaway" | "raffle" | "contest" | "happy_hour"
  name        String
  description String? @db.Text

  active   Boolean   @default(true)
  startsAt DateTime?
  endsAt   DateTime?

  // Happy Hour fields
  multiplier Float?

  // Giveaway / Contest / Raffle fields
  prize         String?
  prizeImageUrl String?
  winnersCount  Int?
  requirement   String?

  // Raffle specific
  ticketPrice       Int?
  maxTicketsPerUser Int?

  // Auto-draw
  autoDrawAt DateTime?
  drawnAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  entries       EventEntry[]
  raffleTickets RaffleTicket[]

  @@index([tenantId])
  @@map("events")
}

model EventEntry {
  id      String @id @default(cuid())
  eventId String
  userId  String

  isWinner  Boolean   @default(false)
  claimedAt DateTime?

  joinedAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_entries")
}

model RaffleTicket {
  id           String @id @default(cuid())
  eventId      String
  userId       String
  ticketNumber Int

  boughtAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("raffle_tickets")
}

// =====================================================
// ACHIEVEMENTS
// =====================================================

model Achievement {
  id          String  @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection
  code        String // unique PER TENANT (see @@unique below) — was globally @unique
  name        String
  description String
  icon        String
  rarity      String // "common" | "rare" | "epic" | "legendary"
  hidden      Boolean @default(false)

  // Trigger conditions (checked by engine)
  triggerType  String? // "level" | "tokens_earned" | "streak" | "messages" | "manual"
  triggerValue Int?

  xpReward    Int     @default(0)
  tokenReward Int     @default(0)
  rewardNote  String? // optional non-token reward shown when earned (game key / item / role / etc.)

  createdAt DateTime @default(now())

  userAchievements UserAchievement[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// =====================================================
// DAILY TASKS
// =====================================================

model DailyTask {
  id       String  @id @default(cuid())
  tenantId String? // multi-tenant (#512) — each portal has its own quests
  code     String // unique PER TENANT (see @@unique below) — was globally @unique
  text     String
  textEn   String?

  target      Int
  reward      Int
  bonusReward Int @default(0)

  triggerType String // "messages" | "voice_minutes" | "drop_code" | "shop_purchase" | "manual"
  active      Boolean @default(true)

  userTasks UserTask[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("daily_tasks")
}

model UserTask {
  id     String @id @default(cuid())
  userId String
  taskId String
  date   String // "YYYY-MM-DD" — resets daily

  progress  Int       @default(0)
  done      Boolean   @default(false)
  claimed   Boolean   @default(false)
  claimedAt DateTime?

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task DailyTask @relation(fields: [taskId], references: [id])

  @@unique([userId, taskId, date])
  @@map("user_tasks")
}

// =====================================================
// SOCIAL LINKS
// =====================================================

model SocialLink {
  id       String @id @default(cuid())
  userId   String
  platform String // "instagram" | "twitter" | "tiktok" | "youtube" | "website"
  handle   String
  url      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("social_links")
}

// =====================================================
// NOTIFICATIONS
// =====================================================

model Notification {
  id     String @id @default(cuid())
  userId String

  type    String // "achievement" | "task_reward" | "shop_delivered" | "event_win" | "system"
  title   String
  message String
  icon    String?
  link    String?
  read    Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // NotificationBell polls {userId} list + {userId, read:false} count every
  // 30-120s per logged-in user — was a seq scan. Covers both + prune by date.
  @@index([userId, createdAt])
  @@index([userId, read])
  @@map("notifications")
}

// =====================================================
// STREAM DROPS
// =====================================================

model StreamDrop {
  id          String  @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3) — collection
  code        String // unique PER TENANT (see @@unique below) — was globally @unique
  reward      Int
  bonusReward Int     @default(0)
  bonusSlots  Int     @default(10) // first N users get bonus

  active      Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  createdById String?

  claims DropClaim[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("stream_drops")
}

// =====================================================
// AUDIT LOG (admin actions — for forensics + security)
// =====================================================

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String // user.id who did the action
  adminName  String? // snapshot of admin username at time of action
  action     String // "grant_tokens" | "create_drop" | "create_event" | "draw_event" | "deliver_order" | "refund_order" | "set_user_role" | "set_connection_role" | "deactivate_drop" | "deactivate_event"
  targetType String? // "user" | "drop" | "event" | "transaction" | "connection"
  targetId   String? // affected entity id
  details    String?  @db.Text // JSON-stringified payload for inspection
  ipAddress  String? // request IP (rough client identification)
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action, createdAt])
  // Admin dashboard reads the global recent log (ORDER BY createdAt DESC) —
  // the composite indexes above don't serve an unfiltered sort.
  @@index([createdAt])
  @@map("admin_actions")
}

// =====================================================
// RATE LIMIT BUCKETS (in-memory fallback; persisted for cross-instance state)
// =====================================================

// =====================================================
// BOT CONFIG — singleton (always id="default")
// Bot fetches from /api/bot/config periodically instead of reading env vars
// =====================================================

model BotConfig {
  id                     String   @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId               String?  @unique // multi-tenant (Phase 3)
  messageReward          Int      @default(5)
  messageCooldownSeconds Int      @default(60)
  voiceRewardPerMinute   Int      @default(10)
  voiceTickSeconds       Int      @default(60)
  afkGivesReward         Boolean  @default(false)
  mutedGivesReward       Boolean  @default(true)
  enabled                Boolean  @default(true)
  // Happy hours: GT-earn multiplier applied PORTAL-SIDE (chat-award / award routes)
  // inside the [start, end) window in Europe/Warsaw — the bot needs no changes.
  happyHourEnabled       Boolean  @default(false)
  happyHourStart         Int      @default(19) // hour 0-23, Europe/Warsaw
  happyHourEnd           Int      @default(22) // exclusive; start>end = overnight window
  happyHourMultiplier    Float    @default(2)
  updatedAt              DateTime @updatedAt

  @@map("bot_config")
}

// =====================================================
// CHAT COMMANDS — managed from /admin#chat, fetched by ghost-empire-chat
// (Twitch/Kick/YouTube bot) periodically. Replaces the bot's hardcoded list.
// =====================================================

model ChatCommand {
  id               String   @id @default(cuid())
  tenantId         String? // multi-tenant (Phase 3 bot models)
  trigger          String // first word that triggers it, e.g. "!portal" (lowercased)
  response         String   @db.Text // text the bot replies with
  cooldownSeconds  Int      @default(15) // per-command cooldown across all chatters
  enabled          Boolean  @default(true) // disabled commands are not sent to the bot
  // Conditional gating (evaluated bot-side from portal live status — Twitch StreamSession)
  requiresLive     Boolean  @default(false) // only fires while the stream is live
  activeFromMinute Int      @default(0) // only after the stream has been live N minutes (0 = always; implies live)
  createdById      String? // admin user id who created it
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // trigger is unique PER TENANT (each portal has its own !commands namespace).
  @@unique([tenantId, trigger])
  @@index([tenantId])
  @@map("chat_commands")
}

// =====================================================
// CHAT TIMERS — cyclic auto-messages the bot posts to all active platforms.
// Managed from /admin#timers, fetched by ghost-empire-chat.
// =====================================================

model ChatTimer {
  id              String   @id @default(cuid())
  tenantId        String? // multi-tenant (Phase 3 bot models)
  message         String   @db.Text // text broadcast on the interval
  intervalSeconds Int      @default(900) // how often to post (min 60s, enforced by the API)
  enabled         Boolean  @default(true)
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@map("chat_timers")
}

// =====================================================
// FAQ / AUTO-RESPONSES — bot replies when a message CONTAINS a keyword
// (not just !commands). Managed from /admin#faq, fetched by ghost-empire-chat.
// =====================================================

model FaqResponse {
