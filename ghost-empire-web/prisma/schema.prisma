// prisma/schema.prisma
// Ghost Empire - Full Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================
// USER & AUTH
// =====================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Identity
  username      String?   @unique
  displayName   String?
  bio           String?

  // Economy
  tokens        Int       @default(0)
  totalEarned   Int       @default(0)
  totalSpent    Int       @default(0)

  // Progression
  level         Int       @default(1)
  xp            Int       @default(0)
  streak        Int       @default(0)
  lastStreakDate String?   // "YYYY-MM-DD"
  lastDaily     DateTime?

  // Stats
  messageCount  Int       @default(0)
  voiceMinutes  Int       @default(0)

  // Discord link
  discordId     String?   @unique
  discordUsername String?

  // Admin & roles
  isAdmin        Boolean   @default(false)
  isModerator    Boolean   @default(false)
  isDonator      Boolean   @default(false)
  totalDonated   Int       @default(0)    // suma donejtów (w jednostkach umownych, np. groszach)
  modNote        String?                   // notatka admina
  modPermissions String[]  @default([])    // ["create_events","grant_tokens","ban_users","manage_shop","draw_events","mark_subs"]

  // Site-level ban/mute (independent of platform bans)
  isBanned       Boolean   @default(false)
  bannedUntil    DateTime?                 // null = permanent
  banReason      String?

  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // App relations
  connections     Connection[]
  transactions    Transaction[]
  userAchievements UserAchievement[]
  userTasks       UserTask[]
  socialLinks     SocialLink[]
  eventEntries    EventEntry[]
  raffleTickets   RaffleTicket[]
  notifications   Notification[]
  donations       Donation[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =====================================================
// PLATFORM CONNECTIONS
// =====================================================

model Connection {
  id           String   @id @default(cuid())
  userId       String
  platform     String   // "twitch" | "kick" | "youtube" | "discord"
  platformId   String   // user's ID on that platform
  username     String
  displayName  String?
  avatar       String?

  // OAuth tokens (encrypted in production)
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  tokenExpiry  DateTime?

  // Sub status
  isSubscriber Boolean  @default(false)
  subTier      String?  // "T1" | "T2" | "T3" | "Prime"
  subMonths    Int      @default(0)
  subStartDate DateTime?

  // Platform role (Twitch mod, Discord admin, Kick mod, etc.)
  isModerator  Boolean  @default(false)  // mod na DANEJ platformie
  isVip        Boolean  @default(false)  // VIP na Twitch / equivalent
  isOG         Boolean  @default(false)  // Kick OG (original supporter)

  // Platform-side ban/mute (set by streamer/mods on tej platformie)
  isBanned     Boolean  @default(false)
  isMuted      Boolean  @default(false)
  banReason    String?

  // Platform metrics
  bits         Int?                       // Twitch lifetime bits cheered
  kickPoints   Int?                       // Kick channel points
  subCount     Int?                       // sub count of THIS user's channel (if streamer themselves)

  // Cached stats (updated via webhook/cron)
  followers    Int?
  following    Int?
  viewCount    Int?

  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@unique([platform, platformId])
  @@map("connections")
}

// =====================================================
// ECONOMY
// =====================================================

model Transaction {
  id     String @id @default(cuid())
  userId String

  type   String // "earn" | "spend" | "admin_grant" | "admin_deduct" | "refund"
  amount Int    // positive = earn, negative = spend

  reason     String
  multiplier Float   @default(1.0)

  // If purchase
  shopItemId String?
  shopItem   ShopItem? @relation(fields: [shopItemId], references: [id])

  // Delivery status (for physical/digital items)
  status String @default("completed") // "pending" | "completed" | "delivered" | "refunded"
  note   String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// =====================================================
// SHOP
// =====================================================

model ShopItem {
  id          String  @id @default(cuid())
  name        String
  description String  @db.Text
  category    String  // "games" | "skins" | "subs" | "cosmetic" | "experience"
  price       Int

  imageUrl    String?
  imageEmoji  String? @default("🎁")

  stock       Int     @default(-1)   // -1 = unlimited
  totalStock  Int     @default(-1)

  hot         Boolean @default(false)
  active      Boolean @default(true)
  featured    Boolean @default(false)

  // Requirements
  requiresSubTier  String?  // "T1" | "T2" | "T3" | "DUAL"
  requiresMinLevel Int?
  requiresMinMonths Int?

  sortOrder   Int     @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]

  @@map("shop_items")
}

// =====================================================
// EVENTS
// =====================================================

model Event {
  id          String  @id @default(cuid())
  type        String  // "giveaway" | "raffle" | "contest" | "happy_hour"
  name        String
  description String? @db.Text

  active      Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?

  // Happy Hour fields
  multiplier  Float?

  // Giveaway / Contest / Raffle fields
  prize         String?
  prizeImageUrl String?
  winnersCount  Int?
  requirement   String?

  // Raffle specific
  ticketPrice   Int?
  maxTicketsPerUser Int?

  // Auto-draw
  autoDrawAt    DateTime?
  drawnAt       DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  entries     EventEntry[]
  raffleTickets RaffleTicket[]

  @@map("events")
}

model EventEntry {
  id       String  @id @default(cuid())
  eventId  String
  userId   String

  isWinner Boolean @default(false)
  claimedAt DateTime?

  joinedAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_entries")
}

model RaffleTicket {
  id      String @id @default(cuid())
  eventId String
  userId  String
  ticketNumber Int

  boughtAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("raffle_tickets")
}

// =====================================================
// ACHIEVEMENTS
// =====================================================

model Achievement {
  id          String @id @default(cuid())
  code        String @unique
  name        String
  description String
  icon        String
  rarity      String // "common" | "rare" | "epic" | "legendary"
  hidden      Boolean @default(false)

  // Trigger conditions (checked by engine)
  triggerType  String?  // "level" | "tokens_earned" | "streak" | "messages" | "manual"
  triggerValue Int?

  xpReward     Int @default(0)
  tokenReward  Int @default(0)

  createdAt DateTime @default(now())

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// =====================================================
// DAILY TASKS
// =====================================================

model DailyTask {
  id      String @id @default(cuid())
  code    String @unique
  text    String
  textEn  String?

  target      Int
  reward      Int
  bonusReward Int @default(0)

  triggerType String // "messages" | "voice_minutes" | "drop_code" | "shop_purchase" | "manual"
  active      Boolean @default(true)

  userTasks UserTask[]

  @@map("daily_tasks")
}

model UserTask {
  id       String @id @default(cuid())
  userId   String
  taskId   String
  date     String // "YYYY-MM-DD" — resets daily

  progress Int     @default(0)
  done     Boolean @default(false)
  claimed  Boolean @default(false)
  claimedAt DateTime?

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task DailyTask @relation(fields: [taskId], references: [id])

  @@unique([userId, taskId, date])
  @@map("user_tasks")
}

// =====================================================
// SOCIAL LINKS
// =====================================================

model SocialLink {
  id       String @id @default(cuid())
  userId   String
  platform String // "instagram" | "twitter" | "tiktok" | "youtube" | "website"
  handle   String
  url      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("social_links")
}

// =====================================================
// NOTIFICATIONS
// =====================================================

model Notification {
  id     String @id @default(cuid())
  userId String

  type    String // "achievement" | "task_reward" | "shop_delivered" | "event_win" | "system"
  title   String
  message String
  icon    String?
  link    String?
  read    Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// =====================================================
// STREAM DROPS
// =====================================================

model StreamDrop {
  id        String   @id @default(cuid())
  code      String   @unique
  reward    Int
  bonusReward Int    @default(0)
  bonusSlots  Int    @default(10)  // first N users get bonus

  active    Boolean  @default(true)
  expiresAt DateTime?
  createdAt DateTime @default(now())
  createdById String?

  claims    DropClaim[]

  @@map("stream_drops")
}

// =====================================================
// AUDIT LOG (admin actions — for forensics + security)
// =====================================================

model AdminAction {
  id          String   @id @default(cuid())
  adminId     String   // user.id who did the action
  adminName   String?  // snapshot of admin username at time of action
  action      String   // "grant_tokens" | "create_drop" | "create_event" | "draw_event" | "deliver_order" | "refund_order" | "set_user_role" | "set_connection_role" | "deactivate_drop" | "deactivate_event"
  targetType  String?  // "user" | "drop" | "event" | "transaction" | "connection"
  targetId    String?  // affected entity id
  details     String?  @db.Text // JSON-stringified payload for inspection
  ipAddress   String?  // request IP (rough client identification)
  createdAt   DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action, createdAt])
  @@map("admin_actions")
}

// =====================================================
// RATE LIMIT BUCKETS (in-memory fallback; persisted for cross-instance state)
// =====================================================

// =====================================================
// BOT CONFIG — singleton (always id="default")
// Bot fetches from /api/bot/config periodically instead of reading env vars
// =====================================================

model BotConfig {
  id                      String   @id @default("default")
  messageReward           Int      @default(5)
  messageCooldownSeconds  Int      @default(60)
  voiceRewardPerMinute    Int      @default(10)
  voiceTickSeconds        Int      @default(60)
  afkGivesReward          Boolean  @default(false)
  mutedGivesReward        Boolean  @default(true)
  enabled                 Boolean  @default(true)
  updatedAt               DateTime @updatedAt

  @@map("bot_config")
}

// =====================================================
// STREAM SCHEDULE
// =====================================================

model StreamScheduleSlot {
  id          String   @id @default(cuid())
  dayOfWeek   Int      // 0=niedziela, 1=poniedziałek, ..., 6=sobota
  startHour   Int      // 0-23
  startMinute Int      @default(0)
  durationMinutes Int  @default(180)  // domyślnie 3h
  title       String?  // np. "Just chatting", "GTA RP"
  platform    String?  // "twitch" | "kick" — gdzie streamuje tego dnia (opcjonalne)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dayOfWeek, active])
  @@map("stream_schedule")
}

// =====================================================
// TWITCH EVENTSUB — broadcaster token + subscriptions + event log
// =====================================================

model TwitchStreamerToken {
  id              String    @id @default("default")  // singleton
  broadcasterId   String                              // Twitch user_id of the streamer (Gh0s77tt)
  broadcasterLogin String                             // Twitch username for display
  accessToken     String    @db.Text
  refreshToken    String?   @db.Text
  tokenExpiresAt  DateTime?
  scope           String                              // space-separated scopes granted
  connectedAt     DateTime  @default(now())
  connectedById   String?                             // admin user id who authorized

  @@map("twitch_streamer_token")
}

model TwitchEventSubscription {
  id              String    @id                       // Twitch's subscription_id
  type            String                              // "channel.subscribe" | "channel.subscription.gift" | "channel.cheer"
  status          String                              // "enabled" | "webhook_callback_verification_pending" | ...
  broadcasterId   String
  createdAt       DateTime  @default(now())
  lastSeenAt      DateTime?                           // last time we received an event of this type

  @@index([type])
  @@map("twitch_event_subscriptions")
}

model TwitchEvent {
  id              String    @id @default(cuid())
  eventId         String    @unique                   // Twitch message_id (for idempotency)
  type            String                              // event type
  payload         String    @db.Text                  // JSON of full event
  userId          String?                             // matched Ghost Empire user
  tokensGranted   Int?
  receivedAt      DateTime  @default(now())

  @@index([type, receivedAt])
  @@map("twitch_events")
}

// =====================================================
// STREAMLABS — singleton connection + donations
// =====================================================

model StreamlabsConnection {
  id                  String    @id @default("default")
  accessToken         String    @db.Text
  refreshToken        String?   @db.Text
  tokenExpiresAt      DateTime?
  scope               String?
  streamlabsUserId    String?
  streamlabsUsername  String?
  lastPolledAt        DateTime?
  lastSeenDonationId  String?   // donation_id of most recent processed
  connectedAt         DateTime  @default(now())
  connectedById       String?   // user.id who initiated OAuth

  @@map("streamlabs_connection")
}

model Donation {
  id              String    @id @default(cuid())
  externalId      String    @unique             // donation_id from provider
  source          String    @default("streamlabs")
  donorName       String
  message         String?   @db.Text
  amountGrosze    Int                            // amount * 100 (PLN cents)
  currency        String    @default("PLN")
  donatedAt       DateTime

  userId          String?                        // matched Ghost Empire user
  matchedAt       DateTime?
  matchType       String?                        // "auto_name" | "auto_mention" | "manual"
  tokensGranted   Int?                           // GT credited to user

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([donatedAt])
  @@index([matchedAt])
  @@map("donations")
}

model DiscordLinkCode {
  code      String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("discord_link_codes")
}

model RateLimitBucket {
  key        String   @id        // e.g. "award:127.0.0.1" or "claim:userId"
  count      Int      @default(0)
  windowStart DateTime
  expiresAt  DateTime

  @@index([expiresAt])
  @@map("rate_limit_buckets")
}

model DropClaim {
  id       String @id @default(cuid())
  dropId   String
  userId   String
  reward   Int    // actual reward received (bonus or regular)
  claimedAt DateTime @default(now())

  drop StreamDrop @relation(fields: [dropId], references: [id])

  @@unique([dropId, userId])
  @@map("drop_claims")
}

// =====================================================
// STREAM ALERTS — OBS overlay queue
// Alerts dispatched by various endpoints; polled by /overlay browser source.
// =====================================================

model StreamAlert {
  id          String   @id @default(cuid())
  type        String   // "shop_purchase" | "event_win" | "drop_claim_bonus" | "twitch_sub" | "twitch_gift_sub" | "twitch_cheer" | "donation" | "welcome" | "level_up" | "test"

  title       String
  message     String
  icon        String?  // emoji shown in overlay

  // Actor (who triggered — for displaying avatar/username on the alert)
  actorName   String?
  actorImage  String?

  // Numeric display (e.g. token amount, bits count, donation kwota)
  amount      Int?
  amountLabel String?  // "GT" | "bits" | "PLN"

  meta        String?  @db.Text  // optional JSON for type-specific extras

  createdAt   DateTime @default(now())
  shownAt     DateTime?  // set when overlay first picks it up

  @@index([createdAt])
  @@map("stream_alerts")
}

// =====================================================
// STREAM ALERT SETTINGS — singleton; per-type enable/disable + visuals
// =====================================================

model StreamAlertSettings {
  id              String   @id @default("default")
  enabledTypes    String[] @default(["shop_purchase","event_win","drop_claim_bonus","twitch_sub","twitch_gift_sub","twitch_cheer","donation","welcome","level_up","test"])
  durationMs      Int      @default(6000)
  accentColor     String   @default("#E50914")
  soundEnabled    Boolean  @default(true)
  overlayToken    String?  // auto-generated on first admin view; rotate via UI to invalidate OBS browser source URLs
  updatedAt       DateTime @updatedAt

  @@map("stream_alert_settings")
}
