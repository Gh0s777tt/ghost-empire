  tenantId        String? // multi-tenant (Phase 3 bot models)
  keyword         String // phrase/word to look for in a message
  matchType       String   @default("contains") // "contains" (substring) | "word" (whole word)
  response        String   @db.Text
  cooldownSeconds Int      @default(30)
  enabled         Boolean  @default(true)
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@map("faq_responses")
}

// =====================================================
// WELCOME — singleton config; bot greets a viewer's first message per stream.
// Managed from /admin#welcome, fetched by ghost-empire-chat.
// =====================================================

model WelcomeConfig {
  id          String   @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId    String?  @unique // multi-tenant (Phase 3)
  enabled     Boolean  @default(false)
  template    String   @default("Witaj {user}! Miło Cię widzieć 👋") @db.Text // {user} = chatter name
  bonusTokens Int      @default(0) // GT przyznawane raz/widz/sesję przy pierwszej wiadomości (0 = off)
  updatedAt   DateTime @updatedAt

  @@map("welcome_config")
}

// =====================================================
// SONG REQUESTS — viewers queue songs via "!sr <link>"; managed on /admin#songs.
// =====================================================

model SongRequest {
  id          String    @id @default(cuid())
  tenantId    String? // multi-tenant (Phase 3 bot models)
  query       String    @db.Text // link or title as typed by the viewer
  title       String? // resolved via oEmbed (YouTube/Spotify), if any
  requestedBy String // chatter display name
  platform    String // "twitch" | "kick" | "youtube"
  status      String    @default("queued") // "queued" | "playing" | "played" | "skipped"
  createdAt   DateTime  @default(now())
  playedAt    DateTime?

  @@index([status, createdAt])
  @@index([tenantId])
  @@map("song_requests")
}

// =====================================================
// CHAT FEED — recent chat messages from all platforms, pushed by the bot and
// shown on the /overlay/chat OBS browser source. Rolling buffer (old rows pruned).
// =====================================================

model ChatFeedMessage {
  id        String   @id @default(cuid())
  tenantId  String? // multi-tenant (Phase 4 overlay pass); null = legacy
  platform  String // "twitch" | "kick" | "youtube"
  username  String
  message   String   @db.Text
  emotes    String?  @db.Text // JSON: Twitch emote map { emoteId: ["start-end", …] } (code-point indices)
  badges    String? // JSON: Twitch badge map { broadcaster:"1", moderator:"1", subscriber:"12", vip:"1", … }
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@map("chat_feed_messages")
}

// =====================================================
// SUBATHON — singleton countdown extended by subs/gifts/donations (lib/subathon.ts).
// Overlay: /overlay/subathon?token=<OVERLAY_TOKEN>. Managed on /admin#subathon.
// =====================================================

model Subathon {
  id             String    @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId       String?   @unique // multi-tenant (Phase 3)
  active         Boolean   @default(false)
  startedAt      DateTime?
  endsAt         DateTime? // current countdown target
  secondsPerSub  Int       @default(300) // +time per sub (incl. gifted)
  secondsPerPln  Int       @default(60) // +time per 1 PLN donated
  maxEndsAt      DateTime? // optional hard cap (null = uncapped)
  totalAddedSecs Int       @default(0) // stat: total seconds added by events
  accentColor    String    @default("#E50914") // overlay card accent (hex)
  label          String    @default("Subathon") // overlay card heading text
  updatedAt      DateTime  @updatedAt

  @@map("subathon")
}

// =====================================================
// CHAT MODERATION — global automod config (singleton). Pure detectors live in
// lib/moderation.ts; the bot fetches this via /api/bot/moderation and enforces
// the action (delete / timeout / warn) on Twitch / Kick / YouTube.
// =====================================================

model ModerationConfig {
  id       String  @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId String? @unique // multi-tenant (Phase 3)
  enabled  Boolean @default(false) // master switch

  profanityEnabled     Boolean  @default(false)
  profanityWords       String[] @default([])
  profanityRegex       String[] @default([]) // power-user regex patterns (profanity action)
  profanityAction      String   @default("delete") // delete | timeout | warn
  profanityTimeoutSecs Int      @default(60)

  // Link / URL filter — blocks links unless their domain is whitelisted.
  linkEnabled     Boolean  @default(false)
  linkWhitelist   String[] @default([]) // allowed domain substrings (e.g. "twitch.tv")
  linkAllowSubs   Boolean  @default(true) // subs/VIP/mods may post links even if rule on
  linkAction      String   @default("delete")
  linkTimeoutSecs Int      @default(60)

  capsEnabled     Boolean @default(false)
  capsMinLetters  Int     @default(8)
  capsMaxRatioPct Int     @default(70) // percent 0-100
  capsAction      String  @default("delete")
  capsTimeoutSecs Int     @default(30)

  lengthEnabled     Boolean @default(false)
  lengthMax         Int     @default(300)
  lengthAction      String  @default("delete")
  lengthTimeoutSecs Int     @default(30)

  repeatEnabled     Boolean @default(false)
  repeatCharRun     Int     @default(8)
  repeatWordRun     Int     @default(4)
  repeatAction      String  @default("delete")
  repeatTimeoutSecs Int     @default(30)

  zalgoEnabled     Boolean @default(false)
  zalgoMaxRatioPct Int     @default(20)
  zalgoAction      String  @default("delete")
  zalgoTimeoutSecs Int     @default(30)

  exemptSubs Boolean @default(true)
  exemptVips Boolean @default(true)
  exemptMods Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("moderation_config")
}

// Per-violation log written by the bot after it enforces an automod action. Powers
// the moderation stats + top-offenders view, and records the escalation level.
model ModViolationLog {
  id         String   @id @default(cuid())
  platform   String // "twitch" | "kick" | "youtube"
  username   String // lowercased login/handle of the offender
  violation  String // "profanity" | "caps" | "length" | "repeat" | "zalgo"
  action     String // enforced action AFTER escalation: "delete" | "timeout" | "warn"
  priorCount Int      @default(0) // offenses already in the window before this one
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([platform, username])
  @@map("mod_violation_logs")
}

// Outgoing webhooks — POST a JSON payload to an external URL (Discord, n8n, Zapier,
// custom) whenever a subscribed stream event fires. Optional HMAC secret signs the
// body (encrypted at rest). failCount auto-disables a dead endpoint.
model OutgoingWebhook {
  id          String    @id @default(cuid())
  tenantId    String? // multi-tenant (#512) — each portal has its own webhooks
  label       String
  url         String    @db.Text
  events      String[]  @default([]) // AlertType values, or ["*"] for every event
  secret      String? // optional HMAC signing secret (encrypted at rest)
  enabled     Boolean   @default(true)
  failCount   Int       @default(0) // consecutive failures; auto-disables at threshold
  lastStatus  Int? // last HTTP status (0 = network error)
  lastFiredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@map("outgoing_webhooks")
}

// =====================================================
// CHAT ACTIVITY HEATMAP — 7×24 buckets (day-of-week × hour, Europe/Warsaw),
// incremented by /api/internal/chat-award. Powers /admin#analytics.
// =====================================================

model ChatActivityBucket {
  dayOfWeek Int // 0=Sun .. 6=Sat (Europe/Warsaw)
  hour      Int // 0-23
  count     Int @default(0)

  @@id([dayOfWeek, hour])
  @@map("chat_activity_buckets")
}

// One broadcast session — opened by Twitch EventSub `stream.online`, closed by
// `stream.offline` (duration computed then). Powers "czas na streamie" + per-stream
// analytics. NB: EventSub only knows when the broadcaster is live, not per-viewer.
model StreamSession {
  id              String    @id @default(cuid())
  platform        String    @default("twitch")
  twitchStreamId  String?   @unique // event.id from stream.online (idempotency)
  startedAt       DateTime
  endedAt         DateTime? // null = currently live
  durationSeconds Int? // set when the stream goes offline
  createdAt       DateTime  @default(now())

  @@index([startedAt])
  @@map("stream_sessions")
}

// =====================================================
// WHEEL OF FORTUNE (Koło Fortuny) — viewers spend GT to spin a weighted wheel
// =====================================================

model WheelConfig {
  id          String   @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId    String?  @unique // multi-tenant (Phase 3)
  enabled     Boolean  @default(false)
  costPerSpin Int      @default(100) // GT charged per spin
  segments    Json? // [{ label, weight, rewardTokens, color }]
  updatedAt   DateTime @updatedAt

  @@map("wheel_config")
}

model WheelSpin {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  segmentLabel String // label of the segment landed on
  rewardTokens Int // GT won (0 = no reward)
  cost         Int // GT spent to spin
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@map("wheel_spins")
}

// =====================================================
// GT MINI-GAMES — slots / coinflip gambling with Ghost Tokens (GT sink + engagement)
// =====================================================

model GtGamePlay {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      String // "slots" | "coinflip"
  bet       Int
  payout    Int // GT returned (0 = lost)
  net       Int // payout - bet
  detail    String? // e.g. slot symbols "🍒🍒🍒"
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([net])
  @@index([userId, createdAt]) // per-user history (casino "your recent games")
  @@map("gt_game_plays")
}

// PvP duel: two viewers stake the same bet, a fair coinflip decides the winner who takes
// the pot (minus a small rake = GT sink). Created by !duel, resolved by !accept. Both
// stakes are charged atomically at accept time (a throw rolls the whole transfer back).
model Duel {
  id             String    @id @default(cuid())
  platform       String // chat platform the duel lives on (twitch/kick/youtube)
  challengerId   String
  challengerName String // chat handle, stored so the result can @-mention correctly
  opponentId     String? // null = open challenge (first !accept takes it)
  opponentName   String? // chat handle of the targeted opponent (null for open)
  bet            Int
  status         String    @default("pending") // pending | resolved | cancelled | expired
  winnerId       String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime // unaccepted duels expire (default 2 min)
  resolvedAt     DateTime?

  challenger User  @relation("DuelChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  opponent   User? @relation("DuelOpponent", fields: [opponentId], references: [id], onDelete: Cascade)
  winner     User? @relation("DuelWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@index([platform, status])
  @@index([challengerId])
  @@index([createdAt])
  @@map("duels")
}

// Co-op heist: viewers join a crew with !heist <bet> over a short window; a collective
// success roll (chance scales with crew size) pays everyone WIN_MULT× on success, else the
// crew loses their stakes. Stakes are escrowed at join (atomic), so resolution only pays out
// the winners (atomic). Result math lives in lib/economy.ts; orchestration in lib/heist.ts.
model Heist {
  id          String       @id @default(cuid())
  platform    String // chat platform the heist lives on
  status      String       @default("open") // open | resolved | cancelled
  startedById String // user who opened the heist
  startedAt   DateTime     @default(now())
  resolvesAt  DateTime // join window closes / resolution time
  resolvedAt  DateTime?
  success     Boolean? // null until resolved
  entries     HeistEntry[]

  @@index([platform, status])
  @@index([resolvesAt])
  @@index([startedAt])
  @@map("heists")
}

model HeistEntry {
  id      String @id @default(cuid())
  heistId String
  heist   Heist  @relation(fields: [heistId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name    String // chat handle (for the result message)
  bet     Int // escrowed at join

  @@unique([heistId, userId]) // one entry per user per heist
  @@index([userId])
  @@map("heist_entries")
}

// =====================================================
// GAME LIBRARY — aggregate owned games from platforms (Steam first; GOG/PSN later)
// =====================================================

model GameLibraryConfig {
  id            String    @id @default(cuid()) // was singleton "default"; now one row per tenant
  tenantId      String?   @unique // multi-tenant (Phase 3)
  steamId       String? // SteamID64 (resolve vanity in admin)
  steamSyncedAt DateTime?
  updatedAt     DateTime  @updatedAt

  @@map("game_library_config")
}

model Game {
  id           String    @id @default(cuid())
  source       String // "steam" | "gog" | "psn" | "xbox"
  externalId   String // platform id (Steam appid, …)
  name         String
  imageUrl     String?
  playtimeMin  Int       @default(0) // total minutes played
  lastPlayedAt DateTime?
  hidden       Boolean   @default(false) // admin can hide a game from /games
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([source, externalId])
  @@index([source, playtimeMin])
  @@map("games")
}

// =====================================================
// STREAM SCHEDULE
// =====================================================

model StreamScheduleSlot {
  id              String   @id @default(cuid())
  tenantId        String? // multi-tenant (Phase 3) — collection: many rows per tenant (NOT unique)
  dayOfWeek       Int // 0=niedziela, 1=poniedziałek, ..., 6=sobota
  startHour       Int // 0-23
  startMinute     Int      @default(0)
  durationMinutes Int      @default(180) // domyślnie 3h
  title           String? // np. "Just chatting", "GTA RP"
  platform        String? // "twitch" | "kick" — gdzie streamuje tego dnia (opcjonalne)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([dayOfWeek, active])
  @@index([tenantId])
  @@map("stream_schedule")
}

// =====================================================
// TWITCH EVENTSUB — broadcaster token + subscriptions + event log
// =====================================================

model TwitchStreamerToken {
  id               String    @id @default(cuid()) // legacy singleton rows keep id "default"
  tenantId         String?   @unique // one streamer token per tenant (null = legacy)
  broadcasterId    String // Twitch user_id of the streamer (Gh0s77tt)
  broadcasterLogin String // Twitch username for display
  accessToken      String    @db.Text
  refreshToken     String?   @db.Text
  tokenExpiresAt   DateTime?
  scope            String // space-separated scopes granted
  connectedAt      DateTime  @default(now())
  connectedById    String? // admin user id who authorized

  @@index([broadcasterId]) // webhook events carry broadcaster_user_id → tenant lookup
  @@map("twitch_streamer_token")
}

model TwitchEventSubscription {
  id            String    @id // Twitch's subscription_id
  type          String // "channel.subscribe" | "channel.subscription.gift" | "channel.cheer"
  status        String // "enabled" | "webhook_callback_verification_pending" | ...
  broadcasterId String
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime? // last time we received an event of this type

  @@index([type])
  @@map("twitch_event_subscriptions")
}

model TwitchEvent {
  id            String   @id @default(cuid())
  eventId       String   @unique // Twitch message_id (for idempotency)
  type          String // event type
  payload       String   @db.Text // JSON of full event
  userId        String? // matched Ghost Empire user
  tokensGranted Int?
  receivedAt    DateTime @default(now())

  @@index([type, receivedAt])
  @@map("twitch_events")
}

// =====================================================
// STREAMLABS — singleton connection + donations
// =====================================================

model StreamlabsConnection {
  id                 String    @id @default(cuid()) // legacy singleton rows keep id "default"
  tenantId           String?   @unique // one connection per tenant (null = legacy)
  accessToken        String    @db.Text
  refreshToken       String?   @db.Text
  tokenExpiresAt     DateTime?
  scope              String?
  streamlabsUserId   String?
  streamlabsUsername String?
  lastPolledAt       DateTime?
  lastSeenDonationId String? // donation_id of most recent processed
  connectedAt        DateTime  @default(now())
  connectedById      String? // user.id who initiated OAuth

  @@map("streamlabs_connection")
}

model Donation {
  id           String   @id @default(cuid())
  externalId   String   @unique // donation_id from provider
  source       String   @default("streamlabs")
  donorName    String
  message      String?  @db.Text
  amountGrosze Int // amount * 100 (PLN cents)
  currency     String   @default("PLN")
  donatedAt    DateTime

  userId        String? // matched Ghost Empire user
  matchedAt     DateTime?
  matchType     String? // "auto_name" | "auto_mention" | "manual"
  tokensGranted Int? // GT credited to user

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([donatedAt])
  @@index([matchedAt])
  @@map("donations")
}

model DiscordLinkCode {
  code      String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("discord_link_codes")
}

model RateLimitBucket {
  key         String   @id // e.g. "award:127.0.0.1" or "claim:userId"
  count       Int      @default(0)
  windowStart DateTime
  expiresAt   DateTime

  @@index([expiresAt])
  @@map("rate_limit_buckets")
}

model DropClaim {
  id        String   @id @default(cuid())
  dropId    String
  userId    String
  reward    Int // actual reward received (bonus or regular)
  claimedAt DateTime @default(now())

  drop StreamDrop @relation(fields: [dropId], references: [id])

  @@unique([dropId, userId])
  @@map("drop_claims")
}

// =====================================================
// STREAM ALERTS — OBS overlay queue
// Alerts dispatched by various endpoints; polled by /overlay browser source.
// =====================================================

model StreamAlert {
  id       String  @id @default(cuid())
  tenantId String? // multi-tenant (Phase 4 overlay pass); null = legacy
  type     String // "shop_purchase" | "event_win" | "drop_claim_bonus" | "twitch_sub" | "twitch_gift_sub" | "twitch_cheer" | "donation" | "welcome" | "level_up" | "test"

  title   String
  message String
  icon    String? // emoji shown in overlay

  // Actor (who triggered — for displaying avatar/username on the alert)
  actorName  String?
  actorImage String?

  // Numeric display (e.g. token amount, bits count, donation kwota)
  amount      Int?
  amountLabel String? // "GT" | "bits" | "PLN"

  meta String? @db.Text // optional JSON for type-specific extras

  createdAt DateTime  @default(now())
  shownAt   DateTime? // set when overlay first picks it up

  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@map("stream_alerts")
}

// =====================================================
// STREAM ALERT SETTINGS — singleton; per-type enable/disable + visuals
// =====================================================

// =====================================================
// BATTLE PASS / SEASONS — monthly-rolling tier progression
// =====================================================

model Season {
  id          String   @id @default(cuid())
  tenantId    String? // multi-tenant (#512) — each portal runs its own battle pass
  number      Int // sequential per tenant: 1, 2, 3, ... (was globally @unique)
  name        String // "Sezon 1: Pierwsza Krew" or "Maj 2026"
  description String?  @db.Text
  startsAt    DateTime
  endsAt      DateTime
  totalTiers  Int      @default(30)
  xpPerTier   Int      @default(5000)
  active      Boolean  @default(true) // false after rollover; only one active at a time
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rewards  SeasonReward[]
  progress UserSeasonProgress[]

  @@unique([tenantId, number])
  @@index([active, endsAt])
  @@index([tenantId])
  @@map("seasons")
}

model SeasonReward {
  id       String  @id @default(cuid())
  seasonId String
  tier     Int // 1..totalTiers
  premium  Boolean @default(false) // false = free track, true = premium pass only
  type     String // "tokens" | "badge" | "title" | "color" | "shop_unlock"
  label    String // display name
  value    String // payload: for tokens => "1000", for badge => achievement code, etc.
  icon     String?

  season Season                  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  claims UserSeasonRewardClaim[]

  @@unique([seasonId, tier, premium])
  @@index([seasonId, tier])
  @@map("season_rewards")
}

model UserSeasonProgress {
  id              String    @id @default(cuid())
  userId          String
  seasonId        String
  xp              Int       @default(0)
  tier            Int       @default(0) // computed from xp / season.xpPerTier
  premium         Boolean   @default(false) // true after buying premium pass
  premiumBoughtAt DateTime?
  updatedAt       DateTime  @updatedAt

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([seasonId, xp])
  @@map("user_season_progress")
}

model UserSeasonRewardClaim {
  id        String   @id @default(cuid())
  userId    String
  rewardId  String
  claimedAt DateTime @default(now())

  reward SeasonReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@unique([userId, rewardId])
  @@index([userId])
  @@map("user_season_reward_claims")
}

// =====================================================
// KICK INTEGRATION — webhooks for subs/gifts/chat (mirror of Twitch EventSub)
