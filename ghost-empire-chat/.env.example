# Ghost Empire Chat Bot — copy to `.env` and fill in.
# `.env` is gitignored (root **/.env) — NEVER put real secrets here in .env.example.

# Portal economy API
PORTAL_URL=https://ghost-empire-web.vercel.app
BOT_SECRET=                  # must equal the portal's BOT_SECRET (same value the Discord bot uses)

# --- Twitch (bot account) ---
TWITCH_BOT_USERNAME=
TWITCH_CHANNEL=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BOT_OAUTH=            # filled by the one-time `npm run auth:twitch`

# --- Kick (bot account) ---
KICK_CHANNEL=               # streamer's channel slug (chat to read); used to look up the chatroom id
KICK_CHATROOM_ID=           # streamer's legacy chatroom id (Pusher subscription); from kick.com/api/v2/channels/<slug> → chatroom.id
KICK_BROADCASTER_ID=        # streamer's user id (channels JSON → user_id); required to send replies (type:"user")
KICK_PUSHER_KEY=            # optional: override Kick's public Pusher app key if it rotates
KICK_CLIENT_ID=             # from dev.kick.com app
KICK_CLIENT_SECRET=         # from dev.kick.com app
KICK_BOT_TOKEN=             # filled by the one-time `npm run auth:kick`
KICK_BOT_REFRESH=           # filled by the one-time `npm run auth:kick` (auto-rotated into .kick-tokens.json)

# --- YouTube (Option C: authorize the CHANNEL account; uses the main Google app) ---
# Setup: enable "YouTube Data API v3" in the Google Cloud project, add http://localhost:3000
# as a Redirect URI, and (if the consent screen is in Testing) add the channel as a Test user.
YOUTUBE_CHANNEL=            # informational only (discovery uses liveBroadcasts.list mine=true)
YOUTUBE_BOT_HANDLE=         # informational
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_BOT_REFRESH_TOKEN=  # filled by the one-time `npm run auth:youtube` (authorize the channel account)
