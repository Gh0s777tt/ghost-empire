# Ghost Empire Chat Bot — copy to `.env` and fill in.
# `.env` is gitignored (root **/.env) — NEVER put real secrets here in .env.example.

# Portal economy API
PORTAL_URL=https://ghost-empire-web.vercel.app
BOT_SECRET=                  # must equal the portal's BOT_SECRET (same value the Discord bot uses)

# --- Twitch (bot account) ---
TWITCH_BOT_USERNAME=
TWITCH_CHANNEL=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BOT_OAUTH=            # filled by the one-time `npm run auth:twitch`

# --- Kick (bot account) ---
KICK_BOT_USERNAME=
KICK_CHANNEL=
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_BOT_TOKEN=             # filled by the one-time `npm run auth:kick`

# --- YouTube (bot account; uses the main Google app) ---
YOUTUBE_CHANNEL=
YOUTUBE_BOT_HANDLE=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_BOT_REFRESH_TOKEN=  # filled by the one-time `npm run auth:youtube`
