# Example per-tenant bot instance (SaaS multi-tenant — one PROCESS per portal).
# Copy to tenants/<slug>.env, fill in, then run:
#   ENV_FILE=tenants/<slug>.env npm start
# Each instance is fully isolated: its own portal URL (the tenant's subdomain),
# its own channels and its own bot credentials.

# The tenant's portal — the subdomain resolves the tenant server-side (Host),
# so every award/command/FAQ/timer call lands in THIS tenant's data.
PORTAL_URL=https://example-tenant.your-product-domain.com
BOT_SECRET=the-same-BOT_SECRET-the-portal-deployment-uses

# Twitch (required)
TWITCH_BOT_USERNAME=YourBotAccount
TWITCH_CHANNEL=tenants_twitch_channel
# oauth via `npm run auth:twitch` (or client-id/secret + refresh below)
# TWITCH_BOT_OAUTH=oauth:xxxxxxxxxxxx
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# TWITCH_BOT_REFRESH=

# Kick (optional — leave unset to disable)
# KICK_CHANNEL=tenants_kick_slug
# KICK_BROADCASTER_ID=
# KICK_CLIENT_ID=
# KICK_CLIENT_SECRET=
# KICK_BOT_TOKEN=
# KICK_BOT_REFRESH=

# YouTube (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# YOUTUBE_BOT_REFRESH_TOKEN=
