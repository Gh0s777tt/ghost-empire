# =====================================================
# GHOST EMPIRE BOT — TEMPLATE
# Skopiuj jako .env i uzupełnij wartości.
# NIGDY nie wpisuj tutaj prawdziwych sekretów (ten plik trafia do gita).
# =====================================================

# --- DISCORD ---
# discord.com/developers/applications -> Bot -> Token (Reset Token)
DISCORD_BOT_TOKEN=

# discord.com/developers/applications -> General Information -> Application ID
DISCORD_CLIENT_ID=

# Discord -> Tryb dewelopera ON -> PPM na serwer -> Kopiuj ID
DISCORD_GUILD_ID=

# --- WEB API ---
# URL strony Ghost Empire (lokalnie / produkcja)
WEB_API_URL=http://localhost:3000

# Ten sam BOT_SECRET co w ghost-empire-web/.env
BOT_SECRET=

# --- TUNABLES (opcjonalne, mają sensowne defaulty) ---
# Tokeny za wiadomość Discord
MESSAGE_REWARD=5
# Cooldown na usera między nagrodami za wiadomości (sekundy)
MESSAGE_COOLDOWN_SECONDS=60
# Tokeny za każdą minutę spędzoną na voice
VOICE_REWARD_PER_MINUTE=10
# Czy AFK channel daje nagrody (default: nie)
AFK_GIVES_REWARD=false
# Czy muteowani userzy na voice dostają tokeny (default: tak — bo słuchanie też się liczy)
MUTED_GIVES_REWARD=true
# Tick voice (sekundy) — co ile sprawdzać kto siedzi na voice
VOICE_TICK_SECONDS=60
