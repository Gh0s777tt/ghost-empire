{
  "$schema": "https://json.schemastore.org/semantic-release.json",
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            { "type": "feat", "section": "Added" },
            { "type": "fix", "section": "Fixed" },
            { "type": "perf", "section": "Changed" },
            { "type": "refactor", "section": "Changed", "hidden": false },
            { "type": "revert", "section": "Changed" },
            { "type": "docs", "hidden": true },
            { "type": "chore", "hidden": true },
            { "type": "test", "hidden": true },
            { "type": "build", "hidden": true },
            { "type": "ci", "hidden": true },
            { "type": "style", "hidden": true }
          ]
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Changelog\n\nWszystkie istotne zmiany w Ghost Empire są opisane w tym pliku.\n\nFormat opiera się na [Keep a Changelog](https://keepachangelog.com/en/1.1.0/).\nWersje datowane (kalendarzowe) zamiast SemVer — projekt jest aplikacją, nie biblioteką."
      }
    ],
    "@semantic-release/gitlab",
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
